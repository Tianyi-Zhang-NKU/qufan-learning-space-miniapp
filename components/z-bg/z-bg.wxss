:host {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.z-bg {
  position: fixed;
  inset: 0;
  overflow: hidden;
  background: #f6efe1;
}

.z-bg-image {
  width: 100%;
  height: 100%;
  opacity: 0.92;
}

.z-bg-wash {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 251, 239, 0.72), rgba(244, 232, 210, 0.9)),
    rgba(255, 248, 234, 0.5);
}
