.z-bg-layer {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
  background: #0b211c;
}

.z-bg-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.z-bg-vignette {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background:
    linear-gradient(180deg, rgba(4, 14, 12, 0.28) 0%, rgba(4, 14, 12, 0.06) 36%, rgba(4, 14, 12, 0.54) 100%),
    linear-gradient(90deg, rgba(4, 14, 12, 0.18), rgba(4, 14, 12, 0) 28%, rgba(4, 14, 12, 0) 72%, rgba(4, 14, 12, 0.18));
}

.z-bg-paper {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  opacity: 0.18;
  background:
    linear-gradient(90deg, rgba(255, 248, 226, 0.04) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(4, 18, 14, 0.16) 1rpx, transparent 1rpx);
  background-size: 90rpx 90rpx, 84rpx 84rpx;
}

.z-bg-layer.auth .z-bg-vignette {
  background: linear-gradient(180deg, rgba(5, 16, 14, 0.08) 0%, rgba(5, 16, 14, 0.28) 42%, rgba(5, 16, 14, 0.82) 100%);
}

.z-bg-layer.light {
  background: #f3ecdc;
}

.z-bg-layer.light .z-bg-vignette {
  background: linear-gradient(180deg, rgba(255, 252, 242, 0.18) 0%, rgba(255, 252, 242, 0.02) 54%, rgba(76, 55, 35, 0.08) 100%);
}

.z-bg-layer.light .z-bg-paper {
  opacity: 0.12;
  background:
    linear-gradient(90deg, rgba(92, 66, 43, 0.04) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(92, 66, 43, 0.035) 1rpx, transparent 1rpx);
  background-size: 86rpx 86rpx, 76rpx 76rpx;
}
