.tile-host {
  display: block;
  width: 100%;
}

.nav-tile {
  display: block;
  min-height: 176rpx;
  padding: 26rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 250, 235, 0.15);
  border-radius: 28rpx;
  color: #fff7e7;
  background: rgba(20, 38, 33, 0.62);
  box-shadow: 0 20rpx 52rpx rgba(0, 0, 0, 0.16);
}

.navigator-hover {
  opacity: 0.88;
}

.tile-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(216, 230, 190, 0.62);
  border-radius: 50%;
  color: #d8e7bd;
  font-size: 24rpx;
  font-weight: 300;
  background: rgba(216, 230, 190, 0.08);
}

.tile-title {
  display: block;
  color: #fff9ec;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1.35;
}

.tile-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(248, 243, 234, 0.6);
  font-size: 21rpx;
  line-height: 1.42;
}
