.qf-role-tabbar {
  position: fixed !important;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  min-height: calc(132rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  padding: 18rpx 38rpx calc(18rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: rgba(255, 252, 244, 0.96);
  border-top: 1rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 -16rpx 48rpx rgba(17, 24, 39, 0.12);
  -webkit-backdrop-filter: blur(24rpx) saturate(1.08);
  backdrop-filter: blur(24rpx) saturate(1.08);
  overflow: visible;
  transform: translateZ(0);
}

.qf-role-tabbar.inline {
  position: relative !important;
  left: auto !important;
  right: auto !important;
  bottom: auto !important;
  z-index: 1;
  flex-shrink: 0;
  margin: 16rpx -34rpx 0;
}

.qf-role-tab {
  position: relative;
  flex: 1;
  min-width: 0;
  min-height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  color: rgba(15, 23, 42, 0.46);
  transition: color 180ms ease, transform 180ms ease;
}

.qf-role-mark {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  color: inherit;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 500;
  background: transparent;
  transition: transform 180ms ease, color 180ms ease, background 180ms ease, box-shadow 180ms ease;
}

.qf-role-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1;
  color: inherit;
}

.qf-role-tab.primary .qf-role-mark {
  width: 108rpx;
  height: 108rpx;
  margin-top: -56rpx;
  border-radius: 50%;
  color: #fffaf0;
  font-size: 58rpx;
  font-weight: 300;
  background: #08133a;
  box-shadow: 0 18rpx 34rpx rgba(8, 19, 58, 0.28);
}

.qf-role-tab.primary .qf-role-text {
  margin-top: 10rpx;
  color: rgba(15, 23, 42, 0.5);
}

.qf-role-tab.active {
  color: #08133a;
}

.qf-role-tab.active:not(.primary) .qf-role-mark {
  color: #365fa8;
  background: #f0f3dd;
}

.qf-role-tab.active:not(.primary)::after {
  content: '';
  width: 8rpx;
  height: 8rpx;
  margin-top: 8rpx;
  border-radius: 50%;
  background: #365fa8;
}

.qf-role-tab.primary.active .qf-role-mark {
  transform: translateY(-4rpx);
  box-shadow: 0 22rpx 42rpx rgba(8, 19, 58, 0.34);
}

.qf-role-tab:active {
  transform: translateY(2rpx);
}
