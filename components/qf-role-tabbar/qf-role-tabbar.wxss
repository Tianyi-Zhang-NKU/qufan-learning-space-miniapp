.qf-role-tabbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 18rpx;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 14rpx 12rpx 24rpx;
  border: 1rpx solid rgba(255, 250, 235, 0.2);
  border-radius: 26rpx;
  background:
    linear-gradient(180deg, rgba(255, 250, 235, 0.08), rgba(255, 250, 235, 0.02)),
    rgba(13, 40, 34, 0.88);
  box-shadow: 0 -16rpx 44rpx rgba(0, 0, 0, 0.24);
}

.qf-role-tab {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(255, 248, 236, 0.68);
}

.qf-role-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  color: rgba(255, 248, 236, 0.8);
  font-size: 21rpx;
  font-weight: 650;
  background: rgba(255, 250, 235, 0.1);
}

.qf-role-text {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1;
}

.qf-role-tab.active {
  color: #FFEDD5;
}

.qf-role-tab.active .qf-role-mark {
  color: #FFF8EC;
  background: #F97316;
}
