.qf-role-tabbar {
  position: fixed !important;
  left: 34rpx;
  right: 34rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 28rpx 11rpx calc(11rpx + env(safe-area-inset-bottom));
  border: 1rpx solid rgba(83, 117, 91, 0.24);
  border-radius: 30rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(255, 250, 238, 0.6)),
    rgba(255, 250, 238, 0.82);
  -webkit-backdrop-filter: blur(28rpx) saturate(1.2);
  backdrop-filter: blur(28rpx) saturate(1.2);
  box-shadow: 0 -18rpx 56rpx rgba(74, 92, 68, 0.22);
  overflow: hidden;
  transform: translateZ(0);
  will-change: transform;
}

/* Inline (non-fixed) variant — used when the page uses scroll-view */
.qf-role-tabbar.inline {
  position: relative !important;
  left: auto !important;
  right: auto !important;
  bottom: auto !important;
  z-index: 1;
  flex-shrink: 0;
  margin-top: 24rpx;
  margin-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: none;
  will-change: auto;
}

.qf-tab-slider {
  position: absolute;
  left: 0;
  top: 18rpx;
  bottom: 11rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(145deg, rgba(249, 115, 22, 0.9), rgba(234, 88, 12, 0.78)),
    rgba(249, 115, 22, 0.8);
  transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

.qf-role-tab {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  min-height: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(31, 53, 46, 0.64);
  transition: color 180ms ease, transform 180ms ease;
}

.qf-role-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  color: inherit;
  font-size: 34rpx;
  line-height: 1;
  transition: transform 180ms ease, color 180ms ease;
}

.qf-role-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1;
}

.qf-role-tab.active {
  color: #fff8ec;
  transform: translateY(-2rpx);
}

.qf-role-tab.active .qf-role-mark {
  color: #fff8ec;
  transform: scale(1.16);
}
