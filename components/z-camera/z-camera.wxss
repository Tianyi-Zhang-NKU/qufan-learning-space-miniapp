.camera-host {
  display: block;
}

.camera-frame {
  position: relative;
  height: 270rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 250, 235, 0.16);
  border-radius: 28rpx;
  background:
    linear-gradient(145deg, rgba(8, 16, 14, 0.96), rgba(20, 39, 33, 0.9)),
    radial-gradient(circle at 50% 42%, rgba(214, 230, 190, 0.18), rgba(214, 230, 190, 0) 160rpx);
}

.camera-frame.muted {
  opacity: 0.72;
}

.camera-frame::before {
  content: "";
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  top: 28rpx;
  bottom: 28rpx;
  border: 1rpx solid rgba(216, 231, 189, 0.18);
  border-radius: 22rpx;
}

.camera-frame::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 90rpx;
  background: linear-gradient(180deg, rgba(5, 12, 10, 0), rgba(5, 12, 10, 0.76));
}

.camera-label {
  position: absolute;
  left: 28rpx;
  bottom: 24rpx;
  z-index: 1;
  color: rgba(248, 243, 234, 0.78);
  font-size: 22rpx;
  line-height: 1.35;
}

.live-dot {
  position: absolute;
  right: 28rpx;
  top: 24rpx;
  z-index: 1;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d6e6be;
  box-shadow: 0 0 28rpx rgba(214, 230, 190, 0.72);
}

.camera-meta {
  padding: 20rpx 8rpx 4rpx;
}

.camera-title {
  display: block;
  color: #fff8ea;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 500;
}

.camera-sub {
  display: block;
  margin-top: 10rpx;
  color: rgba(248, 243, 234, 0.58);
  font-size: 22rpx;
  line-height: 1.42;
}
