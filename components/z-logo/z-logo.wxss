.logo-host {
  display: block;
  width: 112rpx;
  height: 82rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.logo-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 76rpx;
  border: 1rpx solid rgba(248, 243, 234, 0.42);
  border-radius: 50%;
  color: #f8f3ea;
  background: rgba(255, 255, 255, 0.055);
  box-shadow: 0 14rpx 38rpx rgba(0, 0, 0, 0.2);
}

.logo-text {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 400;
}

.logo-host.compact {
  width: 92rpx;
  height: 70rpx;
  margin-right: 18rpx;
}

.logo-host.compact .logo-mark {
  width: 92rpx;
  height: 64rpx;
}

.logo-host.compact .logo-text {
  font-size: 25rpx;
}

.logo-host.auth {
  width: 210rpx;
  height: 128rpx;
  margin-right: 0;
  margin-bottom: 18rpx;
}

.logo-host.auth .logo-mark {
  width: 210rpx;
  height: 118rpx;
  border-radius: 999rpx;
}

.logo-host.auth .logo-text {
  font-size: 48rpx;
  font-weight: 300;
}

.logo-host.paper .logo-mark,
.logo-host.dark .logo-mark,
.logo-host.light .logo-mark {
  color: #2f443b;
  border-color: rgba(47, 68, 59, 0.28);
  background: rgba(47, 68, 59, 0.055);
  box-shadow: none;
}
