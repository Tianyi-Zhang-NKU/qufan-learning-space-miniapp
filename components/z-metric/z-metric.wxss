.metric {
  display: block;
  min-height: 150rpx;
  padding: 24rpx 20rpx;
  border: 1rpx solid rgba(255, 250, 235, 0.14);
  border-radius: 26rpx;
  background: rgba(20, 38, 33, 0.58);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.14);
}

.metric.compact,
.metric.mini {
  min-height: 132rpx;
  padding: 20rpx 16rpx;
}

.metric-value {
  display: block;
  color: #fff8ea;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 500;
}

.metric.compact .metric-value,
.metric.mini .metric-value {
  font-size: 36rpx;
}

.metric-label {
  display: block;
  margin-top: 16rpx;
  color: rgba(248, 243, 234, 0.62);
  font-size: 22rpx;
  line-height: 1.3;
}
