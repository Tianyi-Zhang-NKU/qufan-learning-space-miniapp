.field {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: rgba(248, 243, 234, 0.64);
  font-size: 22rpx;
  line-height: 1.2;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 26rpx;
  border: 1rpx solid rgba(255, 250, 235, 0.18);
  border-radius: 24rpx;
  color: #fff9ec;
  font-size: 28rpx;
  background: rgba(255, 255, 255, 0.07);
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx 26rpx;
  border: 1rpx solid rgba(255, 250, 235, 0.18);
  border-radius: 24rpx;
  color: #fff9ec;
  font-size: 26rpx;
  line-height: 1.55;
  background: rgba(255, 255, 255, 0.07);
}

.placeholder {
  color: rgba(248, 243, 234, 0.34);
}

.field.light .field-label {
  color: rgba(35, 53, 45, 0.58);
}

.field.light .input,
.field.light .textarea {
  color: #22372f;
  border-color: rgba(45, 63, 50, 0.18);
  background: rgba(255, 255, 255, 0.52);
}

.field.light .placeholder {
  color: rgba(35, 53, 45, 0.34);
}
