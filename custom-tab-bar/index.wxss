.tab-shell {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 18rpx;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 14rpx 28rpx;
  border: 1rpx solid rgba(255, 250, 235, 0.14);
  border-radius: 34rpx;
  background: rgba(7, 23, 19, 0.94);
  box-shadow: 0 -18rpx 56rpx rgba(0, 0, 0, 0.24);
}

.tab-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(248, 243, 234, 0.58);
}

.tab-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid rgba(248, 243, 234, 0.18);
  border-radius: 50%;
  color: rgba(248, 243, 234, 0.68);
  font-size: 22rpx;
  font-weight: 300;
  background: rgba(255, 255, 255, 0.04);
}

.tab-text {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1;
}

.tab-item.active {
  color: #d8e7bd;
}

.tab-item.active .tab-mark {
  color: #10231e;
  border-color: rgba(216, 230, 190, 0.8);
  background: #d8e7bd;
  box-shadow: 0 0 28rpx rgba(216, 230, 190, 0.28);
}
