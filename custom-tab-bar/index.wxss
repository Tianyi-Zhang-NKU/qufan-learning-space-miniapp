.tab-shell {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 14rpx calc(14rpx + env(safe-area-inset-bottom));
  border: 1rpx solid rgba(255, 250, 235, 0.14);
  border-radius: 34rpx;
  background: rgba(7, 23, 19, 0.94);
  box-shadow: 0 -18rpx 56rpx rgba(0, 0, 0, 0.24);
  -webkit-backdrop-filter: blur(28rpx) saturate(1.2);
  backdrop-filter: blur(28rpx) saturate(1.2);
  transform: translateZ(0);
  will-change: transform;
}

.tab-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(248, 243, 234, 0.58);
}

.tab-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border: 1rpx solid rgba(248, 243, 234, 0.18);
  border-radius: 50%;
  color: rgba(248, 243, 234, 0.68);
  font-size: 26rpx;
  font-weight: 300;
  background: rgba(255, 255, 255, 0.04);
}

.tab-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1;
}

.tab-item.active {
  color: #d8e7bd;
}

.tab-item.active .tab-mark {
  color: #10231e;
  border-color: rgba(216, 230, 190, 0.8);
  background: #d8e7bd;
  box-shadow: 0 0 28rpx rgba(216, 230, 190, 0.28);
}
