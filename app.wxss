page {
  min-height: 100%;
  color: #1F2937;
  background: #F7FAF6;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  letter-spacing: 0;
}

view,
text,
button,
input,
textarea,
navigator {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  color: inherit;
  background: transparent;
  border: 0;
  border-radius: 0;
}

button::after {
  border: 0;
}

input,
textarea {
  color: #1F2937;
  caret-color: #F97316;
}

navigator {
  color: inherit;
}

.qf-page {
  min-height: 100vh;
  padding: 40rpx 28rpx 170rpx;
  background: linear-gradient(180deg, #173A32 0, #1F4A40 250rpx, #F7FAF6 250rpx, #F7FAF6 100%);
}

.qf-page.plain {
  background: #F7FAF6;
}

.qf-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
  color: #FFF8EC;
}

.qf-brand {
  min-width: 0;
}

.qf-brand-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.2;
}

.qf-brand-sub {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 248, 236, 0.76);
  font-size: 22rpx;
  line-height: 1.35;
}

.qf-title {
  margin: 8rpx 0 22rpx;
  color: #FFF8EC;
  font-size: 46rpx;
  font-weight: 650;
  line-height: 1.18;
}

.qf-card {
  position: relative;
  margin-bottom: 22rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(31, 74, 64, 0.12);
  border-radius: 16rpx;
  background: #FFF8EC;
  box-shadow: 0 16rpx 42rpx rgba(23, 58, 50, 0.11);
}

.qf-card.tight {
  padding: 22rpx;
}

.qf-hero {
  border-color: rgba(255, 237, 213, 0.38);
  background: #FFF8EC;
}

.qf-section {
  margin: 30rpx 0 16rpx;
  color: #173A32;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 1.25;
}

.qf-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.qf-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.qf-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.qf-grid.three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.qf-metric {
  min-height: 118rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #FFEDD5;
}

.qf-metric-value {
  display: block;
  color: #173A32;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
}

.qf-metric-label {
  display: block;
  margin-top: 12rpx;
  color: #6B7F76;
  font-size: 22rpx;
  line-height: 1.25;
}

.qf-h2 {
  display: block;
  color: #173A32;
  font-size: 31rpx;
  font-weight: 650;
  line-height: 1.3;
}

.qf-h3 {
  display: block;
  color: #1F2937;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.35;
}

.qf-text {
  display: block;
  color: #1F2937;
  font-size: 25rpx;
  line-height: 1.55;
}

.qf-muted {
  display: block;
  color: #6B7F76;
  font-size: 23rpx;
  line-height: 1.45;
}

.qf-small {
  font-size: 21rpx;
}

.qf-tag {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #173A32;
  font-size: 21rpx;
  background: #FFEDD5;
}

.qf-tag.ok {
  color: #166534;
  background: rgba(22, 163, 74, 0.13);
}

.qf-tag.warn {
  color: #92400E;
  background: rgba(245, 158, 11, 0.16);
}

.qf-tag.danger {
  color: #B91C1C;
  background: rgba(220, 38, 38, 0.12);
}

.qf-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 14rpx;
  color: #FFF8EC;
  font-size: 25rpx;
  font-weight: 600;
  background: #F97316;
}

.qf-btn:active {
  background: #EA580C;
}

.qf-btn.full {
  width: 100%;
}

.qf-btn.ghost {
  color: #173A32;
  border: 1rpx solid rgba(31, 74, 64, 0.18);
  background: rgba(255, 248, 236, 0.78);
}

.qf-btn.small {
  min-height: 52rpx;
  padding: 0 18rpx;
  font-size: 22rpx;
}

.qf-input,
.qf-textarea {
  width: 100%;
  min-height: 76rpx;
  padding: 0 20rpx;
  margin-top: 12rpx;
  border: 1rpx solid rgba(31, 74, 64, 0.18);
  border-radius: 12rpx;
  color: #1F2937;
  font-size: 25rpx;
  background: #FFFFFF;
}

.qf-textarea {
  min-height: 150rpx;
  padding: 18rpx 20rpx;
  line-height: 1.45;
}

.qf-field {
  margin-bottom: 18rpx;
}

.qf-label {
  display: block;
  color: #173A32;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
}

.qf-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.qf-list-item {
  padding: 20rpx;
  border: 1rpx solid rgba(31, 74, 64, 0.1);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.62);
}

.qf-empty {
  padding: 42rpx 20rpx;
  border: 1rpx dashed rgba(107, 127, 118, 0.38);
  border-radius: 14rpx;
  color: #6B7F76;
  font-size: 24rpx;
  line-height: 1.45;
  text-align: center;
  background: rgba(255, 255, 255, 0.48);
}

.qf-divider {
  height: 1rpx;
  margin: 20rpx 0;
  background: rgba(31, 74, 64, 0.12);
}

.qf-link {
  color: #F97316;
  font-size: 24rpx;
  font-weight: 600;
}

.qf-error {
  color: #DC2626;
}

.qf-safe-bottom {
  height: 24rpx;
}
