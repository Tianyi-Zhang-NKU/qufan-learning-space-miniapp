<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">{{mode === 'course' ? '课程详情' : '课次详情'}}</text>
      <text class="qf-brand-sub">{{mode === 'course' ? detail.course.name : detail.courseSession.displayTitle}}</text>
    </view>
  </view>

  <view wx:if="{{mode === 'course'}}">
    <view class="qf-card qf-hero">
      <text class="qf-h2">{{detail.course.name}}</text>
      <text class="qf-muted">{{detail.course.teacherFullName || detail.course.teacherName}} · {{detail.course.subject}} · 学生 {{detail.course.studentCount}} 人</text>
      <text class="qf-muted">已上传反馈 {{detail.course.feedbackCount}} 条</text>
    </view>

    <view class="qf-section">学生名单</view>
    <view class="qf-card tight">
      <view wx:if="{{detail.students.length}}" class="qf-list">
        <view wx:for="{{detail.students}}" wx:key="id" class="qf-list-item">
          <text class="qf-h3">{{item.name}}</text>
          <text class="qf-muted">{{item.grade}} · {{detail.course.name}}</text>
        </view>
      </view>
      <view wx:else class="qf-empty">暂无学生</view>
    </view>

    <view class="qf-section">课次列表</view>
    <view class="qf-card tight">
      <view wx:if="{{detail.sessions.length}}" class="qf-list">
        <view wx:for="{{detail.sessions}}" wx:key="id" class="qf-list-item">
          <view class="qf-row">
            <view>
              <text class="qf-h3">{{item.sessionTitle}}</text>
              <text class="qf-muted">{{item.displayTitle}} · {{item.date}} {{item.startTime}}-{{item.endTime}}</text>
              <text class="qf-muted">反馈 {{item.feedbackCount}} 条 · 直播入口预留</text>
            </view>
            <button class="qf-btn small" data-id="{{item.id}}" bindtap="openSession">进入课次</button>
          </view>
        </view>
      </view>
      <view wx:else class="qf-empty">暂无课次</view>
    </view>
  </view>

  <view wx:if="{{mode === 'session'}}">
    <view class="qf-card qf-hero">
      <text class="qf-h2">{{detail.courseSession.displayTitle}}</text>
      <text class="qf-muted">{{detail.course.name}} · {{detail.course.teacherFullName || detail.course.teacherName}}</text>
      <text class="qf-muted">{{detail.courseSession.date}} {{detail.courseSession.startTime}}-{{detail.courseSession.endTime}}</text>
      <button class="qf-btn full detail-live" bindtap="goLive">直播入口预留</button>
    </view>

    <view class="qf-section">学生名单</view>
    <view class="qf-card tight">
      <view wx:if="{{detail.students.length}}" class="qf-list">
        <view wx:for="{{detail.students}}" wx:key="id" class="qf-list-item">
          <view class="qf-row">
            <view>
              <text class="qf-h3">{{item.name}}</text>
              <text class="qf-muted">{{item.grade}} · 已有反馈 {{item.feedbackCount || 0}} 条</text>
              <text wx:if="{{item.latestFeedback}}" class="qf-text">{{item.latestFeedback.text}}</text>
            </view>
            <view class="qf-wrap">
              <button wx:if="{{session.role === 'teacher'}}" class="qf-btn small" data-id="{{item.id}}" bindtap="uploadFeedback">上传反馈</button>
              <button wx:if="{{item.latestFeedback}}" class="qf-btn ghost small" data-id="{{item.latestFeedback.id}}" bindtap="viewFeedback">查看反馈</button>
            </view>
          </view>
        </view>
      </view>
      <view wx:else class="qf-empty">暂无学生</view>
    </view>

    <view class="qf-section">课后反馈</view>
    <view class="qf-card tight">
      <view wx:if="{{detail.lessonFeedbacks.length}}" class="qf-list">
        <view wx:for="{{detail.lessonFeedbacks}}" wx:key="id" class="qf-list-item">
          <text class="qf-h3">{{item.studentName}} · {{item.createdAt}}</text>
          <text class="qf-text">{{item.text}}</text>
          <view class="qf-wrap detail-actions">
            <button wx:for="{{item.imageFiles}}" wx:for-item="media" wx:key="id" class="qf-btn ghost small" data-id="{{media.id}}" bindtap="previewMedia">查看图片</button>
            <button wx:for="{{item.voiceFiles}}" wx:for-item="voice" wx:key="id" class="qf-btn ghost small" data-id="{{voice.id}}" bindtap="previewMedia">播放语音</button>
          </view>
        </view>
      </view>
      <view wx:else class="qf-empty">暂无课后反馈</view>
    </view>

    <view class="qf-section">可选测验资料</view>
    <view class="qf-card tight">
      <view wx:if="{{session.role === 'teacher'}}" class="qf-wrap publish-actions">
        <button class="qf-btn ghost small" data-type="pre" bindtap="publishOptionalRecord">保存课前测记录</button>
        <button class="qf-btn ghost small" data-type="post" bindtap="publishOptionalRecord">保存课后测记录</button>
      </view>
      <view wx:if="{{detail.assignments.length}}" class="qf-list">
        <view wx:for="{{detail.assignments}}" wx:key="id" class="qf-list-item">
          <text class="qf-h3">{{item.title}}</text>
          <text class="qf-muted">{{item.typeText}} · {{item.statusText}}</text>
        </view>
      </view>
      <view wx:else class="qf-empty">暂无可选资料</view>
    </view>
  </view>
</view>
