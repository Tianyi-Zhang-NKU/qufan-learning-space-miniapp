<view class="qf-page qf-page-fixed">
  <z-bg mode="dark"></z-bg>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="qf-scroll-body">
    <view class="qf-top">
      <view class="qf-brand">
        <text class="qf-brand-title">{{studentName}} · 错题反馈</text>
        <text class="qf-brand-sub">{{courseName}} · 选择课次和反馈类型</text>
      </view>
    </view>

    <view class="session-nav-wrapper">
      <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="session-nav-scroll">
        <view class="session-nav-inner">
          <view
            wx:for="{{sessions}}"
            wx:key="id"
            class="session-tab {{activeSessionId === item.id ? 'active' : ''}}"
            data-session-id="{{item.id}}"
            bindtap="selectSession"
          >
            <text class="session-tab-title">{{item.sessionTitle || item.displayTitle}}</text>
            <text class="session-tab-date">{{item.date}}</text>
            <text class="session-tab-status-dot {{item.status}}">{{item.statusText || '未开始'}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="qf-section">反馈类型</view>
    <view class="feedback-type-switch">
      <view
        wx:for="{{feedbackTypes}}"
        wx:key="value"
        class="type-pill {{feedbackType === item.value ? 'active' : ''}}"
        data-type="{{item.value}}"
        bindtap="selectFeedbackType"
      >{{item.label}}</view>
    </view>

    <view wx:if="{{existingFeedback}}" class="qf-card existing-feedback">
      <view class="existing-header">
        <text class="qf-h3">已有{{existingFeedback.feedbackTypeText}}</text>
        <text class="qf-muted">{{existingFeedback.createdAt}}</text>
      </view>
      <text class="existing-text">{{existingFeedback.text}}</text>
      <view wx:if="{{existingFeedback.imageCount || existingFeedback.videoCount || existingFeedback.voiceCount}}" class="existing-media-tags">
        <text wx:if="{{existingFeedback.imageCount}}" class="media-tag">图片 {{existingFeedback.imageCount}}</text>
        <text wx:if="{{existingFeedback.videoCount}}" class="media-tag">视频 {{existingFeedback.videoCount}}</text>
        <text wx:if="{{existingFeedback.voiceCount}}" class="media-tag">语音 {{existingFeedback.voiceCount}}</text>
      </view>
    </view>

    <view class="qf-section">文字说明</view>
    <view class="qf-card tight">
      <textarea
        class="feedback-textarea"
        value="{{feedbackText}}"
        placeholder="记录错题原因、讲解重点、学生需要回看的位置等"
        placeholder-style="color: #9aada2;"
        maxlength="2000"
        auto-height
        bindinput="onTextInput"
      ></textarea>
    </view>

    <view class="qf-section">图片 / 视频</view>
    <view class="qf-card tight">
      <view wx:if="{{imageFiles.length || videoFiles.length}}" class="media-preview-list">
        <view wx:for="{{imageFiles}}" wx:key="id" class="media-preview-item">
          <image wx:if="{{item.tempPath}}" class="preview-thumb" src="{{item.tempPath}}" mode="aspectFill"></image>
          <view wx:else class="preview-thumb-placeholder">图</view>
          <text class="preview-name">{{item.name}}</text>
          <button class="remove-btn" data-id="{{item.id}}" data-type="image" bindtap="removeMedia">×</button>
        </view>
        <view wx:for="{{videoFiles}}" wx:key="id" class="media-preview-item">
          <view class="preview-thumb video-thumb">视频</view>
          <text class="preview-name">{{item.name}}</text>
          <button class="remove-btn" data-id="{{item.id}}" data-type="video" bindtap="removeMedia">×</button>
        </view>
      </view>
      <button class="upload-btn" bindtap="chooseMedia">
        <text class="upload-btn-icon">＋</text>
        <text>添加图片或视频</text>
      </button>
    </view>

    <view class="qf-section">语音讲解</view>
    <view class="qf-card tight">
      <view wx:if="{{voiceFiles.length}}" class="voice-preview-list">
        <view wx:for="{{voiceFiles}}" wx:key="id" class="voice-preview-item">
          <view class="voice-mark">声</view>
          <view class="voice-info">
            <text class="voice-name">{{item.name}}</text>
            <text class="voice-meta">{{item.duration || 1}} 秒</text>
          </view>
          <button class="remove-btn inline-remove" data-id="{{item.id}}" data-type="voice" bindtap="removeMedia">×</button>
        </view>
      </view>
      <view class="record-actions">
        <button wx:if="{{!recording}}" class="upload-btn record-btn" bindtap="startRecord">
          <text class="upload-btn-icon">●</text>
          <text>开始录音</text>
        </button>
        <button wx:else class="upload-btn record-btn recording" bindtap="stopRecord">
          <text class="upload-btn-icon">■</text>
          <text>结束录音</text>
        </button>
      </view>
    </view>

    <view class="submit-area">
      <button class="qf-btn full submit-btn" bindtap="submitFeedback" disabled="{{submitting || recording}}">
        {{submitting ? '提交中…' : recording ? '录音中，请先结束' : '保存错题反馈'}}
      </button>
    </view>

    <view class="qf-safe-bottom"></view>
  </scroll-view>

  <qf-role-tabbar role="teacher" current="/pages/teacher/home/home" fixed="{{false}}"></qf-role-tabbar>
</view>
