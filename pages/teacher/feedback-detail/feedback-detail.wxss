/* ============================================
   反馈详情页面样式
   ============================================ */

/* 课次横向滑动导航 — 复用 test-upload 的样式 */
.session-nav-wrapper {
  position: relative;
  z-index: 1;
  margin-bottom: 32rpx;
}

.session-nav-scroll {
  width: 100%;
  white-space: nowrap;
}

.session-nav-inner {
  display: inline-flex;
  gap: 18rpx;
  padding: 4rpx 0;
}

.session-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  min-height: 110rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 250, 235, 0.16);
  background: rgba(18, 42, 35, 0.52);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
  transition: all 160ms ease;
}

.session-tab.active {
  border-color: #f97316;
  background: linear-gradient(145deg, rgba(249, 115, 22, 0.28), rgba(255, 250, 235, 0.08)),
    rgba(20, 48, 40, 0.72);
  box-shadow: 0 12rpx 32rpx rgba(249, 115, 22, 0.22);
}

.session-tab-title {
  display: block;
  color: #fff9ec;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 1.3;
}

.session-tab-date {
  display: block;
  margin-top: 4rpx;
  color: rgba(248, 240, 223, 0.6);
  font-size: 20rpx;
}

.session-tab-status-dot {
  display: inline-block;
  margin-top: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: #fff9ec;
  background: rgba(255, 250, 235, 0.14);
}

.session-tab-status-dot.finished {
  color: #bbf7d0;
  background: rgba(22, 163, 74, 0.22);
}

.session-tab-status-dot.scheduled {
  color: #fed7aa;
  background: rgba(249, 115, 22, 0.18);
}

/* 已有反馈展示 */
.existing-feedback {
  margin-bottom: 28rpx;
}

.existing-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.existing-text {
  display: block;
  font-size: 25rpx;
  line-height: 1.6;
  color: #1f352e;
  white-space: pre-wrap;
}

.existing-media-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.media-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #506157;
  background: rgba(105, 71, 38, 0.08);
}

/* 反馈文本输入 */
.feedback-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #1f352e;
  background: transparent;
}

/* 上传按钮 */
.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 80rpx;
  padding: 0 24rpx;
  margin-top: 8rpx;
  border: 2rpx dashed rgba(83, 117, 91, 0.28);
  border-radius: 18rpx;
  color: #506157;
  font-size: 24rpx;
  background: rgba(105, 71, 38, 0.03);
}

.upload-btn:active {
  background: rgba(249, 115, 22, 0.06);
  border-color: #f97316;
}

.upload-btn-icon {
  font-size: 32rpx;
}

/* 图片预览列表 */
.image-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.image-preview-item {
  position: relative;
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.preview-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(83, 117, 91, 0.16);
}

.preview-thumb-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(83, 117, 91, 0.16);
  background: rgba(105, 71, 38, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.preview-name {
  font-size: 18rpx;
  color: #65756b;
  text-align: center;
  max-width: 140rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.remove-btn {
  position: absolute;
  top: -6rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  line-height: 36rpx;
  text-align: center;
  box-shadow: 0 4rpx 10rpx rgba(239, 68, 68, 0.3);
}

/* 文件预览列表 */
.file-preview-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.file-preview-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(105, 71, 38, 0.04);
}

.file-preview-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.file-preview-info {
  flex: 1;
  min-width: 0;
}

.file-preview-name {
  display: block;
  font-size: 24rpx;
  color: #1f352e;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.file-preview-size {
  display: block;
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #65756b;
}

.file-preview-item .remove-btn {
  position: static;
  flex-shrink: 0;
}

/* 提交区域 */
.submit-area {
  margin-top: 44rpx;
  margin-bottom: 20rpx;
}

.submit-btn {
  min-height: 92rpx;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 26rpx;
}

.submit-btn[disabled] {
  opacity: 0.55;
}
