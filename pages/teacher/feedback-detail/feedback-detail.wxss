.session-nav-wrapper {
  position: relative;
  z-index: 1;
  margin-bottom: 28rpx;
}

.session-nav-scroll {
  width: 100%;
  white-space: nowrap;
}

.session-nav-inner {
  display: inline-flex;
  gap: 18rpx;
  padding: 4rpx 0;
}

.session-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  min-height: 110rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 250, 235, 0.16);
  background: rgba(18, 42, 35, 0.52);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.session-tab.active {
  border-color: #f97316;
  background: linear-gradient(145deg, rgba(249, 115, 22, 0.28), rgba(255, 250, 235, 0.08)),
    rgba(20, 48, 40, 0.72);
  box-shadow: 0 12rpx 32rpx rgba(249, 115, 22, 0.22);
}

.session-tab-title {
  display: block;
  color: #fff9ec;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 1.3;
}

.session-tab-date {
  display: block;
  margin-top: 4rpx;
  color: rgba(248, 240, 223, 0.6);
  font-size: 20rpx;
}

.session-tab-status-dot {
  display: inline-block;
  margin-top: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: #fff9ec;
  background: rgba(255, 250, 235, 0.14);
}

.session-tab-status-dot.finished {
  color: #bbf7d0;
  background: rgba(22, 163, 74, 0.22);
}

.session-tab-status-dot.scheduled {
  color: #fed7aa;
  background: rgba(249, 115, 22, 0.18);
}

.feedback-type-switch {
  max-width: 660rpx;
  margin: 0 auto 28rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.type-pill {
  min-height: 74rpx;
  padding: 0 12rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(255, 249, 236, 0.72);
  background: rgba(18, 42, 35, 0.52);
  border: 1rpx solid rgba(255, 250, 235, 0.14);
}

.type-pill.active {
  color: #fff9ec;
  background: linear-gradient(145deg, #f97316, #ea580c);
  border-color: rgba(255, 249, 236, 0.22);
  box-shadow: 0 12rpx 30rpx rgba(249, 115, 22, 0.22);
}

.existing-feedback {
  margin-bottom: 28rpx;
}

.existing-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.existing-text {
  display: block;
  font-size: 25rpx;
  line-height: 1.6;
  color: #1f352e;
  white-space: pre-wrap;
}

.existing-media-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.media-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #506157;
  background: rgba(105, 71, 38, 0.08);
}

.feedback-textarea {
  width: 100%;
  min-height: 210rpx;
  padding: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #1f352e;
  background: transparent;
}

.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 82rpx;
  padding: 0 24rpx;
  margin-top: 8rpx;
  border: 2rpx dashed rgba(83, 117, 91, 0.28);
  border-radius: 18rpx;
  color: #506157;
  font-size: 24rpx;
  background: rgba(105, 71, 38, 0.03);
}

.upload-btn:active {
  background: rgba(249, 115, 22, 0.06);
  border-color: #f97316;
}

.upload-btn-icon {
  font-size: 30rpx;
  font-weight: 800;
}

.media-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.media-preview-item {
  position: relative;
  width: 166rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.preview-thumb,
.preview-thumb-placeholder {
  width: 146rpx;
  height: 146rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(83, 117, 91, 0.16);
}

.preview-thumb-placeholder,
.video-thumb {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #506157;
  font-size: 24rpx;
  font-weight: 800;
  background: rgba(105, 71, 38, 0.05);
}

.video-thumb {
  color: #0b173d;
  background: linear-gradient(145deg, rgba(219, 234, 254, 0.86), rgba(255, 237, 213, 0.78));
}

.preview-name {
  max-width: 146rpx;
  font-size: 18rpx;
  color: #65756b;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.remove-btn {
  position: absolute;
  top: -8rpx;
  right: 2rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #ef4444;
  color: #fff;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
  box-shadow: 0 4rpx 10rpx rgba(239, 68, 68, 0.3);
}

.voice-preview-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.voice-preview-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(105, 71, 38, 0.04);
  border: 1rpx solid rgba(83, 117, 91, 0.1);
}

.voice-mark {
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff9ec;
  font-size: 20rpx;
  font-weight: 800;
  background: #0b173d;
}

.voice-info {
  flex: 1;
  min-width: 0;
}

.voice-name {
  display: block;
  font-size: 24rpx;
  color: #1f352e;
  font-weight: 650;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.voice-meta {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #65756b;
}

.inline-remove {
  position: static;
  flex-shrink: 0;
}

.record-actions {
  margin-top: 4rpx;
}

.record-btn.recording {
  color: #991b1b;
  border-color: rgba(239, 68, 68, 0.34);
  background: rgba(254, 226, 226, 0.48);
}

.submit-area {
  margin-top: 44rpx;
  margin-bottom: 20rpx;
}

.submit-btn {
  min-height: 92rpx;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 26rpx;
}

.submit-btn[disabled] {
  opacity: 0.55;
}
