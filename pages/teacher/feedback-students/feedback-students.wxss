/* ============================================
   反馈 — 学生名单页面样式
   ============================================ */

/* 概览卡片 */
.summary-card {
  text-align: center;
  margin-bottom: 28rpx;
}

.summary-card .qf-muted {
  margin-top: 8rpx;
}

.summary-stats {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(83, 117, 91, 0.14);
}

.stat-item {
  font-size: 23rpx;
  color: #506157;
  font-weight: 500;
}

/* 学生名单 */
.student-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.student-item {
  cursor: pointer;
}

.student-item:active {
  background: rgba(249, 115, 22, 0.06);
}

.student-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 学生头像 */
.student-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f97316, #ea580c);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  color: #fff9ec;
  font-size: 30rpx;
  font-weight: 700;
}

/* 学生信息 */
.student-info {
  flex: 1;
  min-width: 0;
}

.student-name {
  display: block;
  font-size: 28rpx;
  font-weight: 650;
  color: #173a32;
  line-height: 1.3;
}

.student-meta {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #65756b;
}

/* 箭头 */
.student-arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: #b5c4b8;
  font-weight: 300;
}
