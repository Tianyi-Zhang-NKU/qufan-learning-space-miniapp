<view class="qf-page qf-page-fixed">
  <z-bg mode="dark"></z-bg>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="qf-scroll-body">
    <!-- 顶部标题 -->
    <view class="qf-top">
      <view class="qf-brand">
        <text class="qf-brand-title">{{courseName}} · {{feedbackTypeLabel}}</text>
        <text class="qf-brand-sub">共 {{students.length}} 名学生 · 点击学生录入错题反馈</text>
      </view>
    </view>

    <!-- 课程信息概览 -->
    <view class="qf-card qf-hero summary-card">
      <text class="qf-h2">{{courseName}}</text>
      <text class="qf-muted">{{courseInfo.subject}} · {{courseInfo.grade}} · {{courseInfo.classroomName}} · {{courseInfo.teacherName}}</text>
      <view class="summary-stats">
        <text class="stat-item">📋 {{courseInfo.sessionCount || 0}} 次课</text>
        <text class="stat-item">👥 {{students.length}} 名学生</text>
        <text class="stat-item">📝 {{totalFeedbackCount}} 条{{feedbackTypeLabel}}</text>
      </view>
    </view>

    <!-- 学生名单 -->
    <view wx:if="{{students.length}}" class="qf-section">学生名单</view>
    <view wx:if="{{students.length}}" class="qf-card tight">
      <view class="student-list">
        <view
          wx:for="{{students}}"
          wx:key="id"
          class="student-item qf-list-item"
          data-student-id="{{item.id}}"
          data-student-name="{{item.name}}"
          bindtap="goFeedbackDetail"
        >
          <view class="student-row">
            <view class="student-avatar">
              <text class="avatar-text">{{item.name[0] || '生'}}</text>
            </view>
            <view class="student-info">
              <text class="student-name">{{item.name}}</text>
              <text class="student-meta">{{item.grade || ''}} · 已有 {{item.feedbackCount || 0}} 条{{feedbackTypeLabel}}</text>
            </view>
            <view class="student-arrow">›</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="qf-empty">
      <text>暂无学生数据</text>
      <text class="qf-muted">请确认课程已分配学生</text>
    </view>

    <view class="qf-safe-bottom"></view>
  </scroll-view>

  <qf-role-tabbar role="teacher" current="/pages/teacher/home/home" fixed="{{false}}"></qf-role-tabbar>
</view>
