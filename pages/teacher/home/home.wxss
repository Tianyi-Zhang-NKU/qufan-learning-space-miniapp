/* ============================================
   教师首页 — 课程卡片列表样式
   ============================================ */

/* 课程列表容器 */
.course-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* 单张课程卡片 */
.course-card {
  padding: 36rpx 32rpx 28rpx;
}

/* 课程头部：名称 + 标签 */
.course-header {
  margin-bottom: 24rpx;
}

.course-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #173a32;
  line-height: 1.25;
  margin-bottom: 14rpx;
}

.course-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.course-tag {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 500;
  color: #f97316;
  background: rgba(249, 115, 22, 0.12);
  border: 1rpx solid rgba(249, 115, 22, 0.2);
}

/* 课程详细信息 */
.course-info {
  margin-bottom: 28rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(105, 71, 38, 0.04);
}

.info-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.info-label {
  font-size: 24rpx;
  color: #65756b;
  flex-shrink: 0;
}

.info-value {
  font-size: 24rpx;
  color: #1f352e;
  font-weight: 500;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 三个操作按钮 */
.course-actions {
  display: flex;
  gap: 18rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 110rpx;
  padding: 18rpx 10rpx;
  border-radius: 22rpx;
  border: 0;
  transition: all 120ms ease;
}

.action-btn:active {
  transform: scale(0.96);
  opacity: 0.88;
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.action-label {
  font-size: 23rpx;
  font-weight: 600;
}

/* 课前测按钮 — 蓝绿色调 */
.pre-test-btn {
  color: #fff9ec;
  background: linear-gradient(145deg, #0d9488, #0f766e);
  box-shadow: 0 10rpx 24rpx rgba(13, 148, 136, 0.26);
}

.pre-test-btn:active {
  background: linear-gradient(145deg, #0f766e, #115e59);
}

/* 课后测按钮 — 紫蓝色调 */
.post-test-btn {
  color: #fff9ec;
  background: linear-gradient(145deg, #6366f1, #4f46e5);
  box-shadow: 0 10rpx 24rpx rgba(99, 102, 241, 0.26);
}

.post-test-btn:active {
  background: linear-gradient(145deg, #4f46e5, #4338ca);
}

/* 反馈按钮 — 橙色调（主色调） */
.feedback-btn {
  color: #fff9ec;
  background: linear-gradient(145deg, #fb923c, #ea580c);
  box-shadow: 0 10rpx 24rpx rgba(234, 88, 12, 0.28);
}

.feedback-btn:active {
  background: linear-gradient(145deg, #ea580c, #c2410c);
}
