<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">{{dashboard.teacherName || session.displayName}}</text>
      <text class="qf-brand-sub">教师首页 · 趣帆学习空间</text>
    </view>
    <button class="qf-btn ghost small" bindtap="goCourses">我的课程</button>
  </view>

  <view class="qf-grid">
    <view wx:for="{{dashboard.metrics}}" wx:key="label" class="qf-metric">
      <text class="qf-metric-value">{{item.value}}</text>
      <text class="qf-metric-label">{{item.label}}</text>
    </view>
  </view>

  <view class="qf-section">今日课程</view>
  <view class="qf-card tight">
    <view wx:if="{{dashboard.todayCourses.length}}" class="qf-list">
      <view wx:for="{{dashboard.todayCourses}}" wx:key="id" class="qf-list-item">
        <view class="qf-row">
          <view>
            <text class="qf-h3">{{item.displayTitle}}</text>
            <text class="qf-muted">{{item.courseName}} · {{item.startTime}}-{{item.endTime}} · {{item.classroomName}}</text>
          </view>
          <button class="qf-btn ghost small" data-id="{{item.id}}" bindtap="goSession">进入课次</button>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">今天暂无课程</view>
  </view>

  <view class="qf-section">近期需要反馈的课次</view>
  <view class="qf-card tight">
    <view wx:if="{{dashboard.pendingFeedbackSessions.length}}" class="qf-list">
      <view wx:for="{{dashboard.pendingFeedbackSessions}}" wx:key="id" class="qf-list-item">
        <view class="qf-row">
          <view>
            <text class="qf-h3">{{item.displayTitle}}</text>
            <text class="qf-muted">{{item.courseName}} · 已反馈 {{item.feedbackCount}} / {{item.expectedFeedbackCount}}</text>
          </view>
          <button class="qf-btn small" data-id="{{item.id}}" bindtap="goSession">上传反馈</button>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">近期课次反馈已处理</view>
  </view>

  <view class="qf-section">最近上传的反馈</view>
  <view class="qf-card tight">
    <view wx:if="{{dashboard.recentFeedbacks.length}}" class="qf-list">
      <view wx:for="{{dashboard.recentFeedbacks}}" wx:key="id" class="qf-list-item">
        <text class="qf-h3">{{item.studentName}} · {{item.courseSessionTitle}}</text>
        <text class="qf-muted">{{item.courseName}} · {{item.createdAt}}</text>
        <text class="qf-text">{{item.text}}</text>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无课后反馈</view>
  </view>

  <qf-role-tabbar role="teacher" current="/pages/teacher/home/home"></qf-role-tabbar>
</view>
