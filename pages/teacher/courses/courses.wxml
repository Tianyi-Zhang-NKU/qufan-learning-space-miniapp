<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">我的课程</text>
      <text class="qf-brand-sub">{{teacher.name || session.displayName}} · 课程 / 课次 / 学生 / 反馈</text>
    </view>
  </view>

  <view class="qf-card qf-hero">
    <text class="qf-h2">{{teacher.fullName || teacher.name || session.displayName}}</text>
    <text class="qf-muted">从课程进入课次，在学生名单中上传课后反馈。</text>
  </view>

  <view class="qf-card tight">
    <view wx:if="{{courseGroups.length}}" class="qf-list">
      <view wx:for="{{courseGroups}}" wx:key="id" class="qf-list-item">
        <view class="qf-row">
          <view>
            <text class="qf-h3">{{item.name}}</text>
            <text class="qf-muted">{{item.subject}} · 学生 {{item.studentCount}} 人 · 已上传反馈 {{item.feedbackCount}} 条</text>
            <text class="qf-muted">最近课次：{{item.recentSessionTitle || '暂无课次'}}</text>
          </view>
          <button class="qf-btn ghost small" data-id="{{item.id}}" bindtap="goCourse">进入课程</button>
        </view>
        <view class="qf-divider"></view>
        <view wx:for="{{item.sessions}}" wx:for-item="session" wx:key="id" class="course-session-row">
          <view class="qf-row">
            <view>
              <text class="qf-h3">{{session.sessionTitle}}</text>
              <text class="qf-muted">{{session.displayTitle}} · {{session.date}} {{session.startTime}}-{{session.endTime}}</text>
              <text class="qf-muted">反馈 {{session.feedbackCount}} 条</text>
            </view>
            <button class="qf-btn small" data-id="{{session.id}}" bindtap="goSession">进入课次</button>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无课程</view>
  </view>

  <qf-role-tabbar role="teacher" current="/pages/teacher/courses/courses"></qf-role-tabbar>
</view>
