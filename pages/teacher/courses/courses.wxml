<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">课程管理</text>
      <text class="qf-brand-sub">{{teacher.name || session.displayName}} · 课程班 / 课次 / 学生</text>
    </view>
  </view>

  <view class="qf-card qf-hero">
    <text class="qf-h2">{{teacher.name || session.displayName}}</text>
    <text class="qf-muted">从课程班进入课次，再在学生名单中录入错题。</text>
  </view>

  <view class="qf-card tight">
    <view wx:if="{{courseGroups.length}}" class="qf-list">
      <view wx:for="{{courseGroups}}" wx:key="id" class="qf-list-item">
        <view class="qf-row">
          <view>
            <text class="qf-h3">{{item.name}}</text>
            <text class="qf-muted">{{item.subject}} · {{item.classroomName}} · 学生 {{item.studentCount}} 人</text>
          </view>
          <button class="qf-btn ghost small" data-id="{{item.id}}" bindtap="goCourse">进入课程</button>
        </view>
        <view class="qf-divider"></view>
        <view wx:for="{{item.sessions}}" wx:for-item="session" wx:key="id" class="course-session-row">
          <view class="qf-row">
            <view>
              <text class="qf-h3">{{session.sessionTitle}}</text>
              <text class="qf-muted">{{session.displayTitle}} · {{session.date}} {{session.startTime}}-{{session.endTime}}</text>
            </view>
            <text class="qf-tag {{session.statusTone}}">{{session.statusText}}</text>
          </view>
          <button class="qf-btn ghost small session-entry" data-id="{{session.id}}" bindtap="goSession">进入课次</button>
        </view>
        <view wx:if="{{item.assignments.length}}" class="qf-wrap course-files">
          <block wx:for="{{item.assignments}}" wx:for-item="assignment" wx:key="id">
            <button
              wx:if="{{assignment.file}}"
              class="qf-btn ghost small"
              data-id="{{assignment.file.id}}"
              bindtap="previewFile"
            >{{assignment.title}}</button>
          </block>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无授课安排</view>
  </view>

  <qf-role-tabbar role="teacher" current="/pages/teacher/courses/courses"></qf-role-tabbar>
</view>
