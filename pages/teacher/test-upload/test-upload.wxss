/* ============================================
   课前测 / 课后测 上传页面样式
   ============================================ */

/* 课次横向滑动导航 */
.session-nav-wrapper {
  position: relative;
  z-index: 1;
  margin-bottom: 32rpx;
}

.session-nav-scroll {
  width: 100%;
  white-space: nowrap;
}

.session-nav-inner {
  display: inline-flex;
  gap: 18rpx;
  padding: 4rpx 0;
}

.session-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 200rpx;
  min-height: 120rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 250, 235, 0.16);
  background: rgba(18, 42, 35, 0.52);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
  transition: all 160ms ease;
}

.session-tab.active {
  border-color: #f97316;
  background: linear-gradient(145deg, rgba(249, 115, 22, 0.28), rgba(255, 250, 235, 0.08)),
    rgba(20, 48, 40, 0.72);
  box-shadow: 0 12rpx 32rpx rgba(249, 115, 22, 0.22);
  transform: scale(1.02);
}

.session-tab-title {
  display: block;
  color: #fff9ec;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 1.3;
}

.session-tab-meta {
  display: block;
  margin-top: 6rpx;
  color: rgba(248, 240, 223, 0.6);
  font-size: 20rpx;
  line-height: 1.4;
}

.session-tab-status {
  display: inline-block;
  margin-top: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: #fff9ec;
  background: rgba(255, 250, 235, 0.14);
}

.session-tab-status.finished {
  color: #bbf7d0;
  background: rgba(22, 163, 74, 0.22);
}

.session-tab-status.scheduled {
  color: #fed7aa;
  background: rgba(249, 115, 22, 0.18);
}

/* 当前课次信息 */
.current-session-info {
  text-align: center;
  margin-bottom: 28rpx;
}

.current-session-info .qf-muted {
  margin-top: 8rpx;
}

/* 已上传文件列表 */
.file-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.file-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(83, 117, 91, 0.12);
}

.file-item:last-child {
  border-bottom: 0;
}

.file-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.file-icon {
  font-size: 42rpx;
  flex-shrink: 0;
}

.file-detail {
  min-width: 0;
}

.file-name {
  display: block;
  font-size: 25rpx;
  font-weight: 600;
  color: #1f352e;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.file-meta {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #65756b;
}

/* 上传区域 */
.upload-area {
  text-align: center;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-style: dashed;
  border-color: rgba(83, 117, 91, 0.28);
  cursor: pointer;
}

.upload-area:active {
  background: rgba(249, 115, 22, 0.06);
}

.upload-placeholder,
.upload-progress {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 6rpx;
}

.upload-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f352e;
}

.upload-hint {
  font-size: 22rpx;
  color: #65756b;
}
