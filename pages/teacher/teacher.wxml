<view class="screen teacher-screen">
  <z-bg></z-bg>
  <view class="topbar">
    <view class="brand-row">
      <z-logo></z-logo>
      <view>
        <text class="brand-name">教师端</text>
        <text class="brand-sub">周老师 · 课后反馈</text>
      </view>
    </view>
    <button class="ghost-btn small-ghost" bindtap="logout">退出</button>
  </view>

  <z-card mode="hero">
    <text class="page-kicker">TEACHER DESK</text>
    <view class="page-title">上传课后反馈</view>
    <view class="page-desc">从课程进入课次，再选择学生上传图片、文字和语音。</view>
    <view class="btn-row">
      <navigator class="btn" url="/pages/teacher/courses/courses">我的课程</navigator>
      <navigator class="ghost-btn" url="/pages/wrongbook/wrongbook" open-type="switchTab">反馈样例</navigator>
    </view>
  </z-card>

  <z-card>
    <z-section-title title="当前课次" right="待上传反馈" right-type-alias="status"></z-section-title>
    <z-list-item time="18:30" title="初三生物1班" sub="2 名学生 · ClassIn 入口预留"></z-list-item>
  </z-card>

  <z-card mode="light">
    <z-section-title title="课后记录" right="学生/家长可见" theme="light"></z-section-title>
    <z-field label="文字反馈" placeholder="填写本节课重点、订正建议和复习提醒" type="textarea" theme="light"></z-field>
    <view class="btn-row">
      <view class="btn">保存反馈</view>
      <view class="ghost-btn dark-ghost">添加图片/语音</view>
    </view>
  </z-card>
</view>
