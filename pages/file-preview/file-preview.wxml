<view class="qf-page">
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">文件预览</text>
      <text class="qf-brand-sub">课前测 / 课后测 / 错题图片</text>
    </view>
  </view>

  <view wx:if="{{preview}}" class="qf-card">
    <text class="qf-h2">{{preview.file.name}}</text>
    <text class="qf-muted">类型：{{preview.file.ext}}</text>
    <text class="qf-muted">大小：{{preview.file.size}} bytes</text>
    <view class="qf-divider"></view>
    <view class="qf-empty">{{preview.message}}</view>
    <view class="qf-wrap file-actions">
      <button class="qf-btn {{preview.canPreview ? '' : 'ghost'}}">预览</button>
      <button class="qf-btn ghost">下载</button>
    </view>
  </view>
</view>
