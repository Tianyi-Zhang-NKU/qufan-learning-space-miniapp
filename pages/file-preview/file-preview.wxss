.preview-card {
  overflow: hidden;
}

.preview-block {
  margin-top: 20rpx;
}

.preview-image {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 18rpx;
}

.preview-video {
  width: 100%;
  min-height: 360rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #0b173d;
}

.voice-panel {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(240, 243, 221, 0.72);
  border: 1rpx solid rgba(83, 117, 91, 0.12);
}

.voice-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff9ec;
  font-size: 24rpx;
  font-weight: 800;
  background: #0b173d;
}

.voice-copy {
  flex: 1;
  min-width: 0;
}

.voice-title {
  display: block;
  color: #173a32;
  font-size: 28rpx;
  font-weight: 800;
}

.voice-sub {
  display: block;
  margin-top: 6rpx;
  color: rgba(45, 75, 64, 0.58);
  font-size: 22rpx;
  line-height: 1.45;
}
