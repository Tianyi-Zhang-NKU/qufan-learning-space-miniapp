<view class="qf-page">
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">排课看板</text>
      <text class="qf-brand-sub">教师课表 / 教室课表</text>
    </view>
  </view>

  <view class="qf-card">
    <text class="qf-h2">创建课次</text>
    <input class="qf-input" value="{{form.courseId}}" data-field="courseId" bindinput="input" />
    <input class="qf-input" value="{{form.title}}" data-field="title" bindinput="input" />
    <input class="qf-input" value="{{form.classId}}" data-field="classId" bindinput="input" />
    <input class="qf-input" value="{{form.teacherId}}" data-field="teacherId" bindinput="input" />
    <input class="qf-input" value="{{form.classroomId}}" data-field="classroomId" bindinput="input" />
    <input class="qf-input" value="{{form.date}}" data-field="date" bindinput="input" />
    <view class="qf-grid time-grid">
      <input class="qf-input" value="{{form.startTime}}" data-field="startTime" bindinput="input" />
      <input class="qf-input" value="{{form.endTime}}" data-field="endTime" bindinput="input" />
    </view>
    <view class="qf-wrap form-actions">
      <button class="qf-btn ghost" bindtap="checkConflicts">检查冲突</button>
      <button class="qf-btn" bindtap="save">保存课次</button>
    </view>
  </view>

  <view wx:if="{{conflicts.length}}" class="qf-card tight">
    <text class="qf-h2 qf-error">排课冲突</text>
    <view class="qf-list conflict-list">
      <view wx:for="{{conflicts}}" wx:key="message" class="qf-list-item">
        <text class="qf-tag danger">{{item.label}}</text>
        <text class="qf-muted">{{item.message}}</text>
      </view>
    </view>
  </view>

  <view class="qf-section">现有排课</view>
  <view class="qf-card tight">
    <view class="qf-list">
      <view wx:for="{{bootstrap.courseSessions}}" wx:key="id" class="qf-list-item">
        <text class="qf-h3">{{item.title}}</text>
        <text class="qf-muted">{{item.date}} {{item.startTime}}-{{item.endTime}} · {{item.teacherName}} · {{item.classroomName}}</text>
      </view>
    </view>
  </view>

  <qf-role-tabbar role="admin" current="/pages/admin/schedule-board/schedule-board"></qf-role-tabbar>
</view>
