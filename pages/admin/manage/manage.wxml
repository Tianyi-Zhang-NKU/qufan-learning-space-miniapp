<view class="qf-page qf-page-fixed admin-manage">
  <z-bg mode="dark"></z-bg>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="qf-scroll-body">
    <view class="qf-top">
      <view class="qf-brand">
        <text class="qf-brand-title">数据管理</text>
        <text class="qf-brand-sub">教室、课程、学生与反馈分层查看</text>
      </view>
    </view>

    <view class="qf-card qf-hero admin-hero">
      <text class="qf-h2">课程与教室关系优先</text>
      <text class="qf-muted">先看教室承载，再进入课程、学生和反馈详情。</text>
    </view>

    <view class="qf-entry-grid admin-entry-grid">
      <button class="qf-entry-card {{activePanel === 'classrooms' ? 'active' : ''}}" data-panel="classrooms" bindtap="setPanel">
        <text class="qf-entry-title">教室关系</text>
        <text class="qf-entry-sub">教室 -> 课次 -> 课程</text>
      </button>
      <button class="qf-entry-card {{activePanel === 'teachers' ? 'active' : ''}}" data-panel="teachers" bindtap="setPanel">
        <text class="qf-entry-title">老师关系</text>
        <text class="qf-entry-sub">手机号 -> 课程 -> 学生</text>
      </button>
      <button class="qf-entry-card {{activePanel === 'students' ? 'active' : ''}}" data-panel="students" bindtap="setPanel">
        <text class="qf-entry-title">学生关系</text>
        <text class="qf-entry-sub">点击学生看反馈</text>
      </button>
      <button class="qf-entry-card {{activePanel === 'courses' ? 'active' : ''}}" data-panel="courses" bindtap="setPanel">
        <text class="qf-entry-title">课程课次</text>
        <text class="qf-entry-sub">点击课程看详情</text>
      </button>
      <button class="qf-entry-card {{activePanel === 'phones' ? 'active' : ''}}" data-panel="phones" bindtap="setPanel">
        <text class="qf-entry-title">手机号映射</text>
        <text class="qf-entry-sub">登录身份维护</text>
      </button>
      <button class="qf-entry-card {{activePanel === 'live' ? 'active' : ''}}" data-panel="live" bindtap="setPanel">
        <text class="qf-entry-title">直播配置</text>
        <text class="qf-entry-sub">数据流接入占位</text>
      </button>
    </view>

    <view wx:if="{{activePanel === 'classrooms'}}" class="qf-panel">
      <view class="qf-section">传统课程表</view>
      <scroll-view class="qf-week-scroll" scroll-x enhanced show-scrollbar="{{true}}">
        <view class="qf-week-table">
          <view class="qf-week-row head">
            <view class="qf-week-time">时间</view>
            <view wx:for="{{weekDays}}" wx:key="*this" class="qf-week-cell">{{item}}</view>
          </view>
          <view wx:for="{{weekRows}}" wx:key="time" class="qf-week-row">
            <view class="qf-week-time">{{item.time}}</view>
            <view wx:for="{{item.cells}}" wx:for-item="cell" wx:key="day" class="qf-week-cell">
              <block wx:if="{{cell.sessions.length}}">
                <view wx:for="{{cell.sessions}}" wx:for-item="session" wx:key="id" class="qf-week-course">
                  <text class="qf-week-title">{{session.courseName}}</text>
                  <text class="qf-week-meta">{{session.lesson}}</text>
                  <text class="qf-week-meta">{{session.teacherName}} · {{session.classroomName}}</text>
                </view>
              </block>
              <text wx:else class="qf-week-empty">空</text>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="qf-section">教室 -> 课次 -> 课程</view>
      <view class="qf-card tight admin-loose-card">
        <view wx:if="{{relations.classrooms.length}}" class="qf-list">
          <view wx:for="{{relations.classrooms}}" wx:key="id" class="qf-list-item">
            <text class="qf-h3">{{item.name}} · {{item.cameraStatusText}}</text>
            <text class="qf-muted">{{item.campus}} · 容量 {{item.capacity}} 人</text>
            <view wx:for="{{item.sessions}}" wx:for-item="session" wx:key="id" class="relation-course">
              <text class="qf-text">{{session.date}} {{session.startTime}} · {{session.courseName}} · {{session.displayTitle}}</text>
            </view>
          </view>
        </view>
        <view wx:else class="qf-empty">暂无教室关系</view>
      </view>
    </view>

    <view wx:if="{{activePanel === 'teachers'}}" class="qf-panel">
      <view class="qf-section">老师手机号 -> 课程 -> 学生</view>
      <view class="qf-card tight admin-loose-card">
        <view class="admin-filterbar">
          <input class="qf-input admin-search" placeholder="按老师姓名 / 手机号 / 学科搜索" value="{{filters.teacherKeyword}}" data-field="teacherKeyword" bindinput="onFilterInput" />
          <picker wx:if="{{teacherOptions.length}}" range="{{teacherOptions}}" bindchange="pickTeacher">
            <view class="qf-picker admin-picker">
              <text class="qf-picker-label">选择老师</text>
              <text class="qf-picker-value">{{selectedTeacher.name}} · {{selectedTeacher.subject}}</text>
            </view>
          </picker>
        </view>
        <view wx:if="{{selectedTeacher}}" class="qf-list detail-list">
          <view class="qf-list-item">
            <text class="qf-h3">{{selectedTeacher.name}}</text>
            <text class="qf-muted">{{selectedTeacher.phone}} · {{selectedTeacher.subject}} · {{selectedTeacher.courses.length}} 门课程</text>
            <view wx:for="{{selectedTeacher.courses}}" wx:for-item="course" wx:key="id" class="relation-course">
              <text class="qf-text">{{course.name}} · 学生 {{course.studentCount}} 人</text>
              <text class="qf-muted">学生：{{course.studentsText}}</text>
            </view>
          </view>
        </view>
        <view wx:else class="qf-empty">没有匹配的老师</view>
      </view>
    </view>

    <view wx:if="{{activePanel === 'students'}}" class="qf-panel">
      <view class="qf-section">学生详情与反馈</view>
      <view class="qf-card tight admin-loose-card">
        <view class="admin-filterbar">
          <input class="qf-input admin-search" placeholder="按学生姓名 / 手机号搜索" value="{{filters.studentKeyword}}" data-field="studentKeyword" bindinput="onFilterInput" />
          <picker wx:if="{{studentOptions.length}}" range="{{studentOptions}}" bindchange="pickStudent">
            <view class="qf-picker admin-picker">
              <text class="qf-picker-label">选择学生</text>
              <text class="qf-picker-value">{{selectedStudent.name}} · {{selectedStudent.loginPhone}}</text>
            </view>
          </picker>
        </view>

        <view wx:if="{{selectedStudent}}" class="qf-list detail-list">
          <view class="qf-list-item">
            <text class="qf-h3">{{selectedStudent.name}} · {{selectedStudent.loginPhone}}</text>
            <text class="qf-muted">{{selectedStudent.grade}} · 课程 {{selectedStudent.courses.length}} 门 · 反馈 {{selectedStudent.feedbackCount}} 条</text>
            <view class="qf-wrap relation-actions">
              <button wx:for="{{selectedStudent.courses}}" wx:for-item="course" wx:key="id" class="qf-btn small {{selectedStudentCourseId === course.id ? '' : 'ghost'}}" data-id="{{course.id}}" bindtap="selectStudentCourse">{{course.name}}</button>
            </view>
          </view>

          <view wx:if="{{selectedStudentCourse}}" class="qf-list-item">
            <text class="qf-h3">{{selectedStudentCourse.name}}</text>
            <text class="qf-muted">{{selectedStudentCourse.teacherName}} · {{selectedStudentCourse.classroomName}} · 反馈 {{selectedStudentCourse.feedbackCount}} 条</text>
            <view wx:if="{{selectedStudentCourse.feedbacks.length}}" class="detail-list">
              <view wx:for="{{selectedStudentCourse.feedbacks}}" wx:for-item="feedback" wx:key="id" class="feedback-mini">
                <text class="qf-muted">{{feedback.courseSessionTitle}} · {{feedback.createdAt}}</text>
                <text class="qf-text">{{feedback.text}}</text>
              </view>
            </view>
            <view wx:else class="qf-empty compact-empty">当前课程暂无反馈</view>
          </view>
        </view>
        <view wx:else class="qf-empty">没有匹配的学生</view>
      </view>
    </view>

    <view wx:if="{{activePanel === 'courses'}}" class="qf-panel">
      <view class="qf-section">课程课次详情</view>
      <view class="qf-card tight admin-loose-card">
        <view class="admin-filterbar">
          <input class="qf-input admin-search" placeholder="按课程 / 老师 / 教室搜索" value="{{filters.courseKeyword}}" data-field="courseKeyword" bindinput="onFilterInput" />
          <picker wx:if="{{courseOptions.length}}" range="{{courseOptions}}" bindchange="pickCourse">
            <view class="qf-picker admin-picker">
              <text class="qf-picker-label">选择课程</text>
              <text class="qf-picker-value">{{selectedCourse.name}}</text>
            </view>
          </picker>
        </view>

        <view wx:if="{{selectedCourse}}" class="qf-list detail-list">
          <view class="qf-list-item">
            <text class="qf-h3">{{selectedCourse.name}}</text>
            <text class="qf-muted">{{selectedCourse.teacherName}} · {{selectedCourse.classroomName}} · 共 {{selectedCourse.sessions.length}} 次课 · 学生 {{selectedCourse.studentCount}} 人</text>
            <view wx:for="{{selectedCourse.sessions}}" wx:for-item="session" wx:key="id" class="relation-course course-session-detail">
              <text class="qf-text">{{session.displayTitle}} · {{session.date}} {{session.startTime}}-{{session.endTime}} · 反馈 {{session.feedbackCount}} 条</text>
              <view wx:for="{{session.students}}" wx:for-item="student" wx:key="id" class="feedback-mini">
                <text class="qf-muted">{{student.name}} · 反馈 {{student.feedbackCount}} 条</text>
                <text wx:for="{{student.feedbacks}}" wx:for-item="feedback" wx:key="id" class="qf-text">{{feedback.text}}</text>
              </view>
            </view>
          </view>
        </view>
        <view wx:else class="qf-empty">没有匹配的课程</view>
      </view>
    </view>

    <view wx:if="{{activePanel === 'phones'}}" class="qf-panel">
      <view class="qf-section">登录手机号映射</view>
      <view class="qf-card tight admin-loose-card">
        <view class="admin-filterbar">
          <input class="qf-input admin-search" placeholder="按手机号 / 姓名搜索" value="{{filters.phoneKeyword}}" data-field="phoneKeyword" bindinput="onFilterInput" />
          <picker range="{{phoneRoleOptions}}" value="{{phoneRoleIndex}}" bindchange="pickPhoneRole">
            <view class="qf-picker admin-picker">
              <text class="qf-picker-label">身份类型</text>
              <text class="qf-picker-value">{{phoneRoleOptions[phoneRoleIndex]}}</text>
            </view>
          </picker>
        </view>
        <view wx:if="{{filteredPhoneAccounts.length}}" class="qf-wrap centered-wrap">
          <text wx:for="{{filteredPhoneAccounts}}" wx:key="id" class="qf-tag">{{item.phone}} · {{item.nickname}}</text>
        </view>
        <view wx:else class="qf-empty">没有匹配的手机号</view>
      </view>
    </view>

    <view wx:if="{{activePanel === 'live'}}" class="qf-panel">
      <view class="qf-section">直播接口配置占位</view>
      <view class="qf-card tight admin-loose-card">
        <text class="qf-text center-text">ClassIn 入口由后端或云函数签发。接入真实 `classinEntryUrl` 或播放流后，本界面可直接展示可用状态。</text>
        <view class="qf-wrap centered-wrap">
          <text wx:for="{{overview.liveRooms}}" wx:key="id" class="qf-tag warn">{{item.classroom.name}} 待接入</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <qf-role-tabbar role="admin" current="/pages/admin/manage/manage" fixed="{{false}}"></qf-role-tabbar>
</view>
