<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">数据管理</text>
      <text class="qf-brand-sub">课程维护 / 课次维护 / 手机号映射 / 反馈记录</text>
    </view>
  </view>

  <view class="qf-section">老师手机号 -> 课程 -> 学生</view>
  <view class="qf-card tight">
    <view wx:if="{{relations.teachers.length}}" class="qf-list">
      <view wx:for="{{relations.teachers}}" wx:key="id" class="qf-list-item">
        <text class="qf-h3">{{item.name}} · {{item.phone}}</text>
        <view class="qf-wrap">
          <text wx:for="{{item.courseNames}}" wx:for-item="name" wx:key="*this" class="qf-tag">{{name}}</text>
        </view>
        <view wx:for="{{item.courses}}" wx:for-item="course" wx:key="id" class="relation-course">
          <text class="qf-text">{{course.name}} · 学生 {{course.studentCount}} 人</text>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无老师关系</view>
  </view>

  <view class="qf-section">学生手机号 -> 课程 -> 反馈</view>
  <view class="qf-card tight">
    <view wx:if="{{relations.students.length}}" class="qf-list">
      <view wx:for="{{relations.students}}" wx:key="id" class="qf-list-item">
        <text class="qf-h3">{{item.name}} · {{item.loginPhone}}</text>
        <text class="qf-muted">反馈 {{item.feedbackCount}} 条</text>
        <view class="qf-wrap">
          <text wx:for="{{item.courseNames}}" wx:for-item="name" wx:key="*this" class="qf-tag">{{name}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无学生关系</view>
  </view>

  <view class="qf-section">课程 -> 课次 -> 反馈数量</view>
  <view class="qf-card tight">
    <view wx:if="{{relations.courseTree.length}}" class="qf-list">
      <view wx:for="{{relations.courseTree}}" wx:key="id" class="qf-list-item">
        <text class="qf-h3">{{item.name}}</text>
        <text class="qf-muted">{{item.teacherName}} · 学生 {{item.studentCount}} 人</text>
        <view wx:for="{{item.sessions}}" wx:for-item="session" wx:key="id" class="relation-course">
          <text class="qf-text">{{session.displayTitle}} · 反馈 {{session.feedbackCount}} 条</text>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无课程树</view>
  </view>

  <view class="qf-section">登录手机号映射</view>
  <view class="qf-card tight">
    <view class="qf-wrap">
      <text wx:for="{{bootstrap.phoneAccounts}}" wx:key="id" class="qf-tag">{{item.phone}} · {{item.nickname}}</text>
    </view>
  </view>

  <view class="qf-section">反馈记录查看</view>
  <view class="qf-card tight">
    <view wx:if="{{overview.recentFeedbacks.length}}" class="qf-list">
      <view wx:for="{{overview.recentFeedbacks}}" wx:key="id" class="qf-list-item">
        <text class="qf-h3">{{item.studentName}} · {{item.courseName}}</text>
        <text class="qf-muted">{{item.courseSessionTitle}} · 图片 {{item.imageCount}} · 语音 {{item.voiceCount}}</text>
        <text class="qf-text">{{item.text}}</text>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无反馈记录</view>
  </view>

  <view class="qf-section">直播接口配置占位</view>
  <view class="qf-card tight">
    <text class="qf-text">ClassIn 入口由后端或云函数签发，小程序前端不保存 secret。</text>
    <view class="qf-wrap">
      <text wx:for="{{overview.liveRooms}}" wx:key="id" class="qf-tag warn">{{item.classroom.name}} 待接入</text>
    </view>
  </view>

  <qf-role-tabbar role="admin" current="/pages/admin/manage/manage"></qf-role-tabbar>
</view>
