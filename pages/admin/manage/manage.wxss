.admin-entry-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.admin-loose-card {
  max-width: 660rpx;
  margin-left: auto;
  margin-right: auto;
}

.centered-wrap {
  justify-content: center;
}

.center-text {
  text-align: center;
}

.relation-course {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(83, 117, 91, 0.12);
}

.detail-list {
  margin-top: 26rpx;
}

.feedback-mini {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.42);
}

.course-session-detail {
  padding-bottom: 10rpx;
}
