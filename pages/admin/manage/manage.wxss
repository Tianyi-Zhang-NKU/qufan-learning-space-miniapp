.admin-entry-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  max-width: 620rpx;
}

.admin-loose-card {
  max-width: 660rpx;
  margin-left: auto;
  margin-right: auto;
}

.admin-filterbar {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.admin-search {
  margin-top: 0;
  border-width: 2rpx;
  border-color: rgba(23, 58, 50, 0.28);
  background: rgba(255, 255, 255, 0.88);
}

.admin-picker {
  margin-top: 0;
  border-width: 2rpx;
  border-color: rgba(23, 58, 50, 0.26);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.88), rgba(255, 250, 238, 0.68)),
    rgba(255, 250, 238, 0.86);
}

.centered-wrap {
  justify-content: center;
}

.center-text {
  text-align: center;
}

.relation-course {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(83, 117, 91, 0.12);
}

.detail-list {
  margin-top: 26rpx;
}

.feedback-mini {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.42);
}

.relation-actions {
  margin-top: 24rpx;
  justify-content: flex-start;
}

.compact-empty {
  margin-top: 22rpx;
  padding: 24rpx 16rpx;
}

.course-session-detail {
  padding-bottom: 10rpx;
}
