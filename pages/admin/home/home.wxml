<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">管理首页</text>
      <text class="qf-brand-sub">课程 / 课次 / 关系 / 反馈 / 直播配置</text>
    </view>
    <button class="qf-btn ghost small" bindtap="goManage">数据管理</button>
  </view>

  <view class="qf-grid">
    <view wx:for="{{overview.metrics}}" wx:key="label" class="qf-metric">
      <text class="qf-metric-value">{{item.value}}</text>
      <text class="qf-metric-label">{{item.label}}</text>
    </view>
  </view>

  <view class="qf-section">课程关系总览</view>
  <view class="qf-card tight">
    <view wx:if="{{overview.relationOverview.length}}" class="qf-list">
      <view wx:for="{{overview.relationOverview}}" wx:key="courseId" class="qf-list-item">
        <view class="qf-row">
          <view>
            <text class="qf-h3">{{item.courseName}}</text>
            <text class="qf-muted">{{item.teacherName}} · {{item.classroomName}}</text>
          </view>
          <text class="qf-tag {{item.liveTone}}">{{item.liveStatusText}}</text>
        </view>
        <view class="qf-divider"></view>
        <text class="qf-muted">学生 {{item.studentCount}} 人 · 手机号映射 {{item.phoneAccountCount}} 个 · 反馈 {{item.feedbackCount}} 条</text>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无课程关系</view>
  </view>

  <view class="qf-section">最近反馈</view>
  <view class="qf-card tight">
    <view wx:if="{{overview.recentFeedbacks.length}}" class="qf-list">
      <view wx:for="{{overview.recentFeedbacks}}" wx:key="id" class="qf-list-item">
        <text class="qf-h3">{{item.studentName}} · {{item.courseName}}</text>
        <text class="qf-muted">{{item.courseSessionTitle}} · {{item.createdAt}}</text>
        <text class="qf-text">{{item.text}}</text>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无反馈记录</view>
  </view>

  <view class="qf-section">直播配置状态</view>
  <view class="qf-card tight">
    <view class="qf-wrap">
      <text wx:for="{{overview.liveRooms}}" wx:key="id" class="qf-tag warn">{{item.classroom.name}} ClassIn 待接入</text>
    </view>
  </view>

  <qf-role-tabbar role="admin" current="/pages/admin/home/home"></qf-role-tabbar>
</view>
