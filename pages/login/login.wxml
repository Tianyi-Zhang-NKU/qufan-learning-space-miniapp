<view class="qf-page login-page">
  <z-bg mode="auth"></z-bg>
  <view class="login-brand">
    <text class="login-title">趣帆学习空间</text>
    <text class="login-sub">用报班手机号登录</text>
  </view>

  <view class="qf-card qf-hero">
    <view class="qf-field">
      <text class="qf-label">手机号</text>
      <input
        class="qf-input"
        type="number"
        maxlength="11"
        value="{{phone}}"
        placeholder="请输入手机号"
        bindinput="onPhoneInput"
      />
    </view>

    <button class="qf-btn full" loading="{{logging}}" bindtap="login">登录</button>
    <button class="qf-btn ghost full identity-entry" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">预留微信手机号授权</button>
    <button class="qf-btn ghost full identity-entry" bindtap="smsPlaceholder">预留短信验证码登录</button>
  </view>

  <view class="qf-card tight demo-card">
    <text class="qf-muted qf-small">演示手机号</text>
    <view class="qf-wrap demo-row">
      <button
        wx:for="{{demoPhones}}"
        wx:key="phone"
        class="qf-btn ghost small"
        data-phone="{{item.phone}}"
        bindtap="useDemoPhone"
      >{{item.label}} {{item.phone}}</button>
    </view>
  </view>
</view>
