.exercises-screen {
  padding-top: 52rpx;
}

.paper-card {
  margin-top: 4rpx;
}

.paper-line {
  display: flex;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(45, 63, 50, 0.12);
}

.paper-line:last-child {
  border-bottom: 0;
}

.paper-index {
  flex: 0 0 70rpx;
  color: #5b7a4f;
  font-size: 24rpx;
  font-weight: 600;
}

.paper-text {
  flex: 1;
  color: #253a32;
  font-size: 26rpx;
  line-height: 1.58;
}

.dark-ghost {
  color: #253a32;
  border-color: rgba(45, 63, 50, 0.2);
  background: rgba(45, 63, 50, 0.06);
}

.metric.mini {
  min-height: 132rpx;
  padding: 20rpx 16rpx;
}

.metric.mini .metric-value {
  font-size: 36rpx;
}

.compact-title {
  margin-top: 0;
}
