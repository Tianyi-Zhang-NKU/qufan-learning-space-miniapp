<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">我的学习</text>
      <text class="qf-brand-sub">{{dashboard.currentStudent.name || session.displayName}} · 趣帆学习空间</text>
    </view>
  </view>

  <view class="qf-grid">
    <view wx:for="{{dashboard.metrics}}" wx:key="label" class="qf-metric">
      <text class="qf-metric-value">{{item.value}}</text>
      <text class="qf-metric-label">{{item.label}}</text>
    </view>
  </view>

  <view class="qf-section">我的课程</view>
  <view class="qf-card tight">
    <view wx:if="{{dashboard.courses.length}}" class="qf-list">
      <view wx:for="{{dashboard.courses}}" wx:key="id" class="qf-list-item">
        <view class="qf-row">
          <view>
            <text class="qf-h3">{{item.name}}</text>
            <text class="qf-muted">{{item.teacherName}} · {{item.sessions.length}} 次课 · 反馈 {{item.feedbackCount}} 条</text>
          </view>
          <button class="qf-btn ghost small" bindtap="goCourses">查看</button>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无课程</view>
  </view>

  <view class="qf-section">最近反馈</view>
  <view class="qf-card tight">
    <view wx:if="{{dashboard.recentFeedbacks.length}}" class="qf-list">
      <view wx:for="{{dashboard.recentFeedbacks}}" wx:key="id" class="qf-list-item">
        <text class="qf-h3">{{item.courseName}} · {{item.courseSessionTitle}}</text>
        <text class="qf-muted">{{item.teacherName}} · {{item.createdAt}}</text>
        <text class="qf-text">{{item.text}}</text>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无老师反馈</view>
    <button class="qf-btn full" bindtap="goFeedbacks">查看全部反馈</button>
  </view>

  <view class="qf-section">今日课程</view>
  <view class="qf-card tight">
    <view wx:if="{{dashboard.todayCourses.length}}" class="qf-list">
      <view wx:for="{{dashboard.todayCourses}}" wx:key="id" class="qf-list-item">
        <view class="qf-row">
          <view>
            <text class="qf-h3">{{item.displayTitle}}</text>
            <text class="qf-muted">{{item.courseName}} · {{item.startTime}}-{{item.endTime}} · {{item.teacherName}}</text>
          </view>
          <button class="qf-btn ghost small" data-id="{{item.id}}" bindtap="goLive">直播入口</button>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">今天暂无课程</view>
  </view>

  <view class="qf-section">直播入口</view>
  <view class="qf-card tight">
    <text class="qf-text">上课直播入口已保留，正式部署后接入 ClassIn 或真实服务器。</text>
  </view>

  <qf-role-tabbar role="parent" current="/pages/parent/home/home"></qf-role-tabbar>
</view>
