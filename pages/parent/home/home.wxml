<view class="qf-page qf-page-fixed">
  <z-bg mode="dark"></z-bg>

  <scroll-view scroll-y enhanced show-scrollbar="{{false}}" class="qf-scroll-body">
    <!-- Header -->
    <view class="qf-top">
      <view class="qf-brand">
        <text class="qf-brand-title">我的学习</text>
        <text class="qf-brand-sub">{{studentName || session.displayName}} · 课程首页</text>
      </view>
    </view>

    <!-- Summary strip -->
    <view class="home-summary-strip">
      <view class="home-summary-item">
        <text class="home-summary-value">{{courses.length}}</text>
        <text class="home-summary-label">已报课程</text>
      </view>
      <view class="home-summary-item">
        <text class="home-summary-value">{{courses[0].sessionCount || 0}}</text>
        <text class="home-summary-label">课次安排</text>
      </view>
      <view class="home-summary-item">
        <text class="home-summary-value">课前测</text>
        <text class="home-summary-label">预习巩固</text>
      </view>
      <view class="home-summary-item">
        <text class="home-summary-value">课后测</text>
        <text class="home-summary-label">效果检验</text>
      </view>
    </view>

    <!-- Section title -->
    <view class="qf-section">我的课程</view>

    <!-- Loading state -->
    <view wx:if="{{loading}}" class="qf-empty">
      <text>加载中…</text>
    </view>

    <!-- Empty state -->
    <view wx:elif="{{!courses.length}}" class="qf-empty">
      <text>暂无已报课程</text>
      <text class="qf-muted">请联系教务老师报班</text>
    </view>

    <!-- Course cards -->
    <view wx:else class="course-list">
      <view
        wx:for="{{courses}}"
        wx:key="id"
        class="qf-card course-card"
      >
        <!-- Course header -->
        <view class="course-header">
          <view class="course-title-row">
            <text class="course-name">{{item.name}}</text>
            <text class="qf-tag ok" wx:if="{{item.subject}}">{{item.subject}}</text>
          </view>
          <text class="course-grade" wx:if="{{item.grade}}">{{item.grade}}</text>
        </view>

        <!-- Course info: teacher, time, location -->
        <view class="course-info">
          <view class="course-info-row">
            <text class="course-info-icon">👨‍🏫</text>
            <text class="course-info-label">任课教师</text>
            <text class="course-info-value">{{item.teacherName || '待分配'}}</text>
          </view>
          <view class="course-info-row">
            <text class="course-info-icon">📍</text>
            <text class="course-info-label">上课地点</text>
            <text class="course-info-value">{{item.classroomName}}</text>
          </view>
          <view class="course-info-row" wx:if="{{item.nextSessionTime}}">
            <text class="course-info-icon">🕐</text>
            <text class="course-info-label">最近上课</text>
            <text class="course-info-value">{{item.nextSessionTime}}</text>
          </view>
        </view>

        <!-- Session schedule lines -->
        <view class="course-schedule" wx:if="{{item.scheduleLines.length}}">
          <view wx:for="{{item.scheduleLines}}" wx:key="*this" class="schedule-line">
            <text class="schedule-dot"></text>
            <text class="schedule-text">{{item}}</text>
          </view>
        </view>

        <!-- Action buttons: pre-test / post-test -->
        <view class="course-actions">
          <button
            class="qf-btn test-btn pre-test-btn"
            data-id="{{item.id}}"
            bindtap="goPreTests"
          >
            <text class="test-btn-icon">📝</text>
            <view class="test-btn-text">
              <text class="test-btn-title">课前测</text>
              <text class="test-btn-sub" wx:if="{{item.totalPreCount}}">{{item.totalPreCount}} 份记录</text>
              <text class="test-btn-sub" wx:else>暂无记录</text>
            </view>
          </button>

          <button
            class="qf-btn test-btn post-test-btn"
            data-id="{{item.id}}"
            bindtap="goPostTests"
          >
            <text class="test-btn-icon">✅</text>
            <view class="test-btn-text">
              <text class="test-btn-title">课后测</text>
              <text class="test-btn-sub" wx:if="{{item.totalPostCount}}">{{item.totalPostCount}} 份记录</text>
              <text class="test-btn-sub" wx:else>暂无记录</text>
            </view>
          </button>
        </view>
      </view>
    </view>

    <view class="qf-safe-bottom"></view>
  </scroll-view>

  <qf-role-tabbar role="parent" current="/pages/parent/home/home" fixed="{{false}}"></qf-role-tabbar>
</view>
