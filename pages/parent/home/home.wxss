.child-row {
  margin-top: 18rpx;
}

.course-action {
  margin-top: 16rpx;
}

.parent-hero,
.home-summary-strip,
.home-action-list,
.parent-panel {
  max-width: 660rpx;
  margin-left: auto;
  margin-right: auto;
}

.parent-hero {
  margin-bottom: 42rpx;
  padding: 48rpx 42rpx;
}

.home-summary-strip {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: stretch;
  margin-bottom: 52rpx;
  padding: 28rpx 18rpx;
  border: 1rpx solid rgba(83, 117, 91, 0.18);
  border-radius: 32rpx;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.74), rgba(255, 250, 238, 0.44)),
    rgba(255, 250, 238, 0.62);
  -webkit-backdrop-filter: blur(24rpx) saturate(1.12);
  backdrop-filter: blur(24rpx) saturate(1.12);
  box-shadow: 0 18rpx 50rpx rgba(74, 92, 68, 0.13);
}

.home-summary-item {
  flex: 1;
  min-width: 0;
  padding: 0 12rpx;
  text-align: center;
}

.home-summary-item + .home-summary-item {
  border-left: 1rpx solid rgba(83, 117, 91, 0.16);
}

.home-summary-value {
  display: block;
  color: #173a32;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.home-summary-label {
  display: block;
  margin-top: 12rpx;
  color: rgba(45, 75, 64, 0.66);
  font-size: 21rpx;
  line-height: 1.25;
}

.home-action-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-bottom: 58rpx;
}

.home-action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 158rpx;
  padding: 34rpx 36rpx;
  text-align: left;
  border: 1rpx solid rgba(83, 117, 91, 0.2);
  border-radius: 32rpx;
  color: #173a32;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.78), rgba(255, 247, 232, 0.46)),
    rgba(255, 250, 238, 0.66);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
  box-shadow: 0 18rpx 48rpx rgba(74, 92, 68, 0.14);
}

.home-action-card.active {
  color: #fff9ec;
  border-color: rgba(234, 88, 12, 0.42);
  background:
    linear-gradient(145deg, #f97316, #d95b11),
    #f97316;
  box-shadow: 0 22rpx 58rpx rgba(249, 115, 22, 0.3);
}

.home-action-copy {
  flex: 1;
  min-width: 0;
}

.home-action-card .qf-entry-title {
  font-size: 32rpx;
}

.home-action-card .qf-entry-sub {
  margin-top: 12rpx;
  font-size: 23rpx;
}

.home-action-card.active .qf-entry-sub {
  color: rgba(255, 249, 236, 0.78);
}

.home-action-chip {
  flex: 0 0 auto;
  min-width: 82rpx;
  min-height: 48rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(31, 74, 64, 0.14);
  border-radius: 999rpx;
  color: rgba(45, 75, 64, 0.74);
  font-size: 21rpx;
  font-weight: 600;
  line-height: 48rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.58);
}

.home-action-card.active .home-action-chip {
  color: #fff9ec;
  border-color: rgba(255, 249, 236, 0.32);
  background: rgba(255, 249, 236, 0.14);
}

.parent-panel .qf-section {
  margin-top: 0;
}

.parent-panel .qf-card.tight {
  padding: 36rpx;
}

.parent-panel .qf-btn.full {
  margin-top: 28rpx;
}
