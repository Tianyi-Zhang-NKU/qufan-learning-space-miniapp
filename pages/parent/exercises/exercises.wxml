<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">课后反馈</text>
      <text class="qf-brand-sub">{{currentStudent.name || session.displayName}} · 老师上传的课后反馈</text>
    </view>
  </view>

  <view class="qf-card qf-hero">
    <text class="qf-h2">老师反馈</text>
    <text class="qf-muted">图片可查看和下载，语音只支持收听。</text>
    <view class="qf-wrap filter-row">
      <button class="qf-btn small {{selectedCourseId ? 'ghost' : ''}}" data-id="" bindtap="setCourse">全部</button>
      <button
        wx:for="{{courses}}"
        wx:key="id"
        class="qf-btn small {{selectedCourseId === item.id ? '' : 'ghost'}}"
        data-id="{{item.id}}"
        bindtap="setCourse"
      >{{item.name}}</button>
    </view>
  </view>

  <view class="qf-card tight">
    <view wx:if="{{feedbacks.length}}" class="qf-list">
      <view wx:for="{{feedbacks}}" wx:key="id" class="qf-list-item">
        <text class="qf-h3">{{item.courseName}} · {{item.courseSessionTitle}}</text>
        <text class="qf-muted">{{item.teacherName}} · {{item.createdAt}}</text>
        <text class="qf-text">{{item.text}}</text>

        <view wx:if="{{item.imageFiles.length}}" class="qf-wrap feedback-media">
          <button wx:for="{{item.imageFiles}}" wx:for-item="media" wx:key="id" class="qf-btn ghost small" data-id="{{media.id}}" bindtap="previewMedia">查看图片</button>
          <button wx:for="{{item.imageFiles}}" wx:for-item="media" wx:key="id" class="qf-btn ghost small" data-id="{{media.id}}" bindtap="downloadImage">下载图片</button>
        </view>

        <view wx:if="{{item.voiceFiles.length}}" class="qf-wrap feedback-media">
          <button wx:for="{{item.voiceFiles}}" wx:for-item="voice" wx:key="id" class="qf-btn ghost small" data-id="{{voice.id}}" bindtap="playVoice">播放语音</button>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无课后反馈</view>
  </view>

  <qf-role-tabbar role="parent" current="/pages/parent/exercises/exercises"></qf-role-tabbar>
</view>
