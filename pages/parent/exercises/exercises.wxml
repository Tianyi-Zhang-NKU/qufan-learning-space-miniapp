<view class="qf-page">
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">习题中心</text>
      <text class="qf-brand-sub">{{currentChild.name || '当前孩子'}}</text>
    </view>
  </view>

  <view class="qf-card tight">
    <view class="qf-wrap">
      <button
        wx:for="{{children}}"
        wx:key="id"
        class="qf-btn small {{session.activeChildId === item.id ? '' : 'ghost'}}"
        data-id="{{item.id}}"
        bindtap="switchChild"
      >{{item.name}}</button>
    </view>
    <view class="qf-wrap filter-row">
      <button class="qf-btn small {{filter === 'all' ? '' : 'ghost'}}" data-filter="all" bindtap="setFilter">全部</button>
      <button class="qf-btn small {{filter === 'assignment' ? '' : 'ghost'}}" data-filter="assignment" bindtap="setFilter">测验</button>
      <button class="qf-btn small {{filter === 'wrong' ? '' : 'ghost'}}" data-filter="wrong" bindtap="setFilter">错题</button>
    </view>
  </view>

  <view wx:if="{{filter === 'all' || filter === 'assignment'}}" class="qf-section">课前测 / 课后测</view>
  <view wx:if="{{filter === 'all' || filter === 'assignment'}}" class="qf-card tight">
    <view wx:if="{{assignments.length}}" class="qf-list">
      <view wx:for="{{assignments}}" wx:key="id" class="qf-list-item qf-row">
        <view>
          <text class="qf-h3">{{item.title}}</text>
          <text class="qf-muted">{{item.typeText}} · {{item.statusText}}</text>
          <text class="qf-muted">{{item.courseSession.title}}</text>
        </view>
        <button wx:if="{{item.file}}" class="qf-btn ghost small" data-id="{{item.file.id}}" bindtap="previewFile">文件</button>
        <text wx:else class="qf-tag warn">文件未上传</text>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无测验</view>
  </view>

  <view wx:if="{{filter === 'all' || filter === 'wrong'}}" class="qf-section">错题记录</view>
  <view wx:if="{{filter === 'all' || filter === 'wrong'}}" class="qf-card tight">
    <view wx:if="{{wrongRecords.length}}" class="qf-list">
      <view wx:for="{{wrongRecords}}" wx:key="id" class="qf-list-item">
        <view class="qf-row">
          <text class="qf-h3">{{item.topic}}</text>
          <text class="qf-tag {{item.status === 'corrected' ? 'ok' : 'warn'}}">{{item.statusText}}</text>
        </view>
        <text class="qf-muted">{{item.subject}} · {{item.source}}</text>
        <text class="qf-text">{{item.correction}}</text>
      </view>
    </view>
    <view wx:else class="qf-empty">暂无错题记录</view>
  </view>

  <qf-role-tabbar role="parent" current="/pages/parent/exercises/exercises"></qf-role-tabbar>
</view>
