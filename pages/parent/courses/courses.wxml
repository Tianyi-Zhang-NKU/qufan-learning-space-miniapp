<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">我的课程</text>
      <text class="qf-brand-sub">{{currentStudent.name || session.displayName}} · 当前手机号绑定学生</text>
    </view>
  </view>

  <view class="qf-card tight">
    <view wx:if="{{courseGroups.length}}" class="qf-list">
      <view wx:for="{{courseGroups}}" wx:key="id" class="qf-list-item">
        <view class="qf-row">
          <view>
            <text class="qf-h3">{{item.name}}</text>
            <text class="qf-muted">{{item.teacherName}} · {{item.sessions.length}} 次课 · 反馈 {{item.feedbackCount}} 条</text>
          </view>
          <button class="qf-btn ghost small" data-id="{{item.id}}" bindtap="goDetail">课程详情</button>
        </view>
        <view class="qf-divider"></view>
        <view wx:for="{{item.sessions}}" wx:for-item="session" wx:key="id" class="course-session-row">
          <view class="qf-row">
            <view>
              <text class="qf-h3">{{session.sessionTitle}}</text>
              <text class="qf-muted">{{session.displayTitle}} · {{session.date}} {{session.startTime}}-{{session.endTime}}</text>
              <text class="qf-muted">反馈 {{session.feedbackCount}} 条 · 上课直播入口预留</text>
            </view>
            <view class="qf-wrap">
              <button class="qf-btn ghost small" data-id="{{session.id}}" bindtap="goSession">反馈</button>
              <button class="qf-btn ghost small" data-id="{{session.id}}" bindtap="goLive">直播入口</button>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">当前学生暂无课程</view>
  </view>

  <qf-role-tabbar role="parent" current="/pages/parent/courses/courses"></qf-role-tabbar>
</view>
