<view class="qf-page">
  <z-bg mode="dark"></z-bg>
  <view class="qf-top">
    <view class="qf-brand">
      <text class="qf-brand-title">我的课程</text>
      <text class="qf-brand-sub">{{currentStudent.name || session.displayName}} · 当前手机号绑定学生</text>
    </view>
  </view>

  <view class="qf-section">传统课程表</view>
  <scroll-view class="qf-week-scroll" scroll-x enhanced show-scrollbar="{{true}}">
    <view class="qf-week-table">
      <view class="qf-week-row head">
        <view class="qf-week-time">时间</view>
        <view wx:for="{{weekDays}}" wx:key="*this" class="qf-week-cell">{{item}}</view>
      </view>
      <view wx:for="{{weekRows}}" wx:key="time" class="qf-week-row">
        <view class="qf-week-time">{{item.time}}</view>
        <view wx:for="{{item.cells}}" wx:for-item="cell" wx:key="day" class="qf-week-cell">
          <block wx:if="{{cell.sessions.length}}">
            <view wx:for="{{cell.sessions}}" wx:for-item="session" wx:key="id" class="qf-week-course" data-id="{{session.id}}" bindtap="goSession">
              <text class="qf-week-title">{{session.courseName}}</text>
              <text class="qf-week-meta">{{session.lesson}}</text>
              <text class="qf-week-meta">{{session.classroom}} · 反馈 {{session.feedbackCount}} 条</text>
            </view>
          </block>
          <text wx:else class="qf-week-empty">空</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="qf-section">课程列表</view>
  <view class="qf-card tight">
    <view wx:if="{{courseGroups.length}}" class="qf-list">
      <view wx:for="{{courseGroups}}" wx:key="id" class="qf-list-item">
        <view class="qf-row">
          <view>
            <text class="qf-h3">{{item.name}}</text>
            <text class="qf-muted">{{item.teacherName}} · {{item.sessions.length}} 次课 · 反馈 {{item.feedbackCount}} 条</text>
          </view>
          <button class="qf-btn ghost small" data-id="{{item.id}}" bindtap="goDetail">课程详情</button>
        </view>
      </view>
    </view>
    <view wx:else class="qf-empty">当前学生暂无课程</view>
  </view>

  <qf-role-tabbar role="parent" current="/pages/parent/courses/courses"></qf-role-tabbar>
</view>
