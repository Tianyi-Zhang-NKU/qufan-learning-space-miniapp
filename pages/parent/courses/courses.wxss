/* ===== Calendar Card ===== */
.calendar-card {
  position: relative;
  z-index: 1;
  margin-bottom: 32rpx;
  padding: 36rpx 30rpx 28rpx;
  border: 1rpx solid rgba(83, 117, 91, 0.22);
  border-radius: 34rpx;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.7), rgba(255, 248, 232, 0.36)),
    rgba(255, 250, 238, 0.56);
  -webkit-backdrop-filter: blur(30rpx) saturate(1.16);
  backdrop-filter: blur(30rpx) saturate(1.16);
  box-shadow: 0 26rpx 76rpx rgba(74, 92, 68, 0.2);
}

/* Month header with nav arrows */
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding: 0 8rpx;
}

.calendar-month {
  font-size: 34rpx;
  font-weight: 700;
  color: #173a32;
  font-family: "Noto Serif CJK SC", "Source Han Serif SC", "SimSun", "HarmonyOS Sans SC", serif;
}

.calendar-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.64);
  border: 1rpx solid rgba(83, 117, 91, 0.16);
  transition: background 120ms;
}

.calendar-nav:active {
  background: rgba(249, 115, 22, 0.12);
}

.calendar-nav-arrow {
  font-size: 38rpx;
  font-weight: 300;
  color: #173a32;
  line-height: 1;
  margin-top: -4rpx;
}

/* Weekday labels */
.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
  margin-bottom: 12rpx;
}

.calendar-weekday {
  text-align: center;
  font-size: 23rpx;
  font-weight: 600;
  color: #65756b;
  padding: 10rpx 0;
}

/* Day grid */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
}

.calendar-day {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  padding: 8rpx 0;
  border-radius: 18rpx;
  transition: background 120ms;
}

.calendar-day-num {
  font-size: 26rpx;
  font-weight: 500;
  color: #1f352e;
  line-height: 1;
}

/* Today highlight */
.calendar-day.today .calendar-day-num {
  color: #f97316;
  font-weight: 700;
}

.calendar-day.today {
  background: rgba(249, 115, 22, 0.08);
}

/* Selected date */
.calendar-day.selected {
  background: #f97316;
  box-shadow: 0 8rpx 22rpx rgba(249, 115, 22, 0.28);
}

.calendar-day.selected .calendar-day-num {
  color: #fff9ec;
  font-weight: 700;
}

/* Other month (dimmed) */
.calendar-day.other-month .calendar-day-num {
  color: rgba(31, 53, 46, 0.22);
}

/* Course dot indicator */
.calendar-dot {
  width: 8rpx;
  height: 8rpx;
  margin-top: 6rpx;
  border-radius: 50%;
  background: #f97316;
}

.calendar-day.selected .calendar-dot {
  background: #fff9ec;
}

.calendar-day.other-month .calendar-dot {
  background: rgba(249, 115, 22, 0.3);
}

/* ===== Course Cards ===== */
.course-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.course-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(83, 117, 91, 0.18);
  border-radius: 28rpx;
  color: #1f352e;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.82), rgba(255, 250, 238, 0.48)),
    rgba(255, 250, 238, 0.68);
  box-shadow: 0 16rpx 44rpx rgba(74, 92, 68, 0.14);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.course-info {
  flex: 1;
  min-width: 0;
}

.course-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #173a32;
  line-height: 1.3;
  margin-bottom: 14rpx;
}

.course-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.course-meta text {
  display: block;
  font-size: 22rpx;
  color: rgba(45, 75, 64, 0.72);
  line-height: 1.4;
}

/* ===== Test Buttons ===== */
.course-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  flex-shrink: 0;
}

.test-btn {
  min-width: 128rpx;
  font-size: 22rpx;
}

.pre-test {
  background: linear-gradient(145deg, #fb923c, #ea580c), #f97316;
  border-color: rgba(194, 65, 12, 0.26);
}

.post-test {
  background: linear-gradient(145deg, #4ade80, #16a34a), #22c55e;
  border-color: rgba(21, 128, 61, 0.26);
}
