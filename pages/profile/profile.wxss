/* ===== 教师端头部 ===== */
.teacher-header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
}

/* 头像 */
.avatar-wrapper {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f97316, #ea580c);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 42rpx rgba(249, 115, 22, 0.34);
  border: 4rpx solid rgba(255, 249, 236, 0.6);
}

.avatar-text {
  color: #fff9ec;
  font-size: 56rpx;
  font-weight: 700;
  font-family: "Noto Serif CJK SC", "Source Han Serif SC", serif;
}

.avatar-badge {
  position: absolute;
  bottom: -4rpx;
  right: -8rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: #fff9ec;
  background: #22c55e;
  border: 3rpx solid rgba(255, 249, 236, 0.9);
  box-shadow: 0 4rpx 12rpx rgba(34, 197, 94, 0.28);
}

.teacher-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #173a32;
  line-height: 1.2;
  margin-bottom: 6rpx;
}

.teacher-sub {
  display: block;
  font-size: 24rpx;
  color: #65756b;
  margin-bottom: 4rpx;
}

.teacher-phone {
  display: block;
  font-size: 22rpx;
  color: #8a9d92;
}

/* ===== 数据概览 ===== */
.stats-grid {
  position: relative;
  z-index: 1;
  max-width: 660rpx;
  margin: 32rpx auto;
}

.stat-metric {
  text-align: center;
}

/* ===== 合集卡片 ===== */
.collection-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.collection-card {
  cursor: pointer;
}

.collection-card:active {
  background: rgba(249, 115, 22, 0.04);
}

.collection-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.collection-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.course-icon {
  background: rgba(249, 115, 22, 0.12);
}

.student-icon {
  background: rgba(99, 102, 241, 0.12);
}

.collection-info {
  flex: 1;
  min-width: 0;
}

.collection-name {
  display: block;
  font-size: 27rpx;
  font-weight: 650;
  color: #173a32;
  line-height: 1.3;
}

.collection-meta {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #65756b;
  line-height: 1.4;
}

.collection-arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: #b5c4b8;
  font-weight: 300;
}

/* ===== 通用：共享样式 ===== */
.profile-hero,
.profile-card {
  max-width: 660rpx;
  margin-left: auto;
  margin-right: auto;
}

.profile-logout {
  position: relative;
  z-index: 1;
  max-width: 660rpx;
  margin: 44rpx auto 0;
}
